<!DOCTYPE html>
<!-- saved from url=(0055) -->
<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LinkCore v6 — Backlink Project Manager</title>
<link href="./LinkCore v6 — Backlink Project Manager_files/css2" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#09090b;--bg2:#111115;--bg3:#18181d;--bg4:#1e1e25;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);
  --accent:#00ff88;--accent-dim:rgba(0,255,136,0.08);--accent-glow:rgba(0,255,136,0.25);
  --blue:#3b82f6;--blue-dim:rgba(59,130,246,0.1);
  --orange:#f59e0b;--orange-dim:rgba(245,158,11,0.1);
  --red:#ef4444;--red-dim:rgba(239,68,68,0.08);
  --purple:#a855f7;--purple-dim:rgba(168,85,247,0.1);
  --text:#e8eaf0;--muted:#6b7280;--muted2:#3d4350;
  --mono:'Space Mono',monospace;--display:'Unbounded',sans-serif;
  --r:12px;
}
html{scroll-behavior:smooth}
body{font-family:var(--mono);background:var(--bg);color:var(--text);min-height:100vh;font-size:12px;line-height:1.6;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,255,136,0.018) 1px,transparent 1px),linear-gradient(90deg,rgba(0,255,136,0.018) 1px,transparent 1px);background-size:48px 48px;pointer-events:none;z-index:0}

/* ── Layout ── */
.app{position:relative;z-index:1;display:grid;grid-template-columns:260px 1fr;min-height:100vh}

/* ── Sidebar ── */
.sidebar{background:var(--bg2);border-right:1px solid var(--border);padding:24px 16px;display:flex;flex-direction:column;gap:8px;position:sticky;top:0;height:100vh;overflow-y:auto}
.sidebar::-webkit-scrollbar{width:3px}
.sidebar::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

.brand{display:flex;align-items:center;gap:10px;padding:0 4px 20px;border-bottom:1px solid var(--border);margin-bottom:8px}
.brand-logo{width:36px;height:36px;background:var(--accent);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;animation:glow 3s ease-in-out infinite}
@keyframes glow{0%,100%{box-shadow:0 0 16px var(--accent-glow)}50%{box-shadow:0 0 32px rgba(0,255,136,.45)}}
.brand-name{font-family:var(--display);font-size:.95rem;font-weight:800;color:#fff}
.brand-sub{font-size:.5rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase}

.sb-label{font-size:.52rem;color:var(--muted);text-transform:uppercase;letter-spacing:.12em;padding:0 4px;margin-top:8px;margin-bottom:4px}

.sb-btn{width:100%;text-align:left;background:none;border:1px solid transparent;border-radius:8px;padding:9px 12px;font-family:var(--mono);font-size:.7rem;color:var(--muted);cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:8px}
.sb-btn:hover{background:var(--bg3);border-color:var(--border);color:var(--text)}
.sb-btn.active{background:var(--accent-dim);border-color:rgba(0,255,136,.25);color:var(--accent)}
.sb-btn .dot{width:6px;height:6px;border-radius:50%;background:var(--muted2);flex-shrink:0;transition:background .15s}
.sb-btn.active .dot{background:var(--accent);box-shadow:0 0 6px var(--accent)}
.sb-btn .cnt{margin-left:auto;font-size:.55rem;background:var(--bg4);border-radius:4px;padding:1px 6px;color:var(--muted)}
.sb-btn.active .cnt{background:rgba(0,255,136,.15);color:var(--accent)}

.new-proj-btn{width:100%;background:var(--accent-dim);border:1px dashed rgba(0,255,136,.3);border-radius:8px;padding:9px 12px;font-family:var(--mono);font-size:.68rem;color:var(--accent);cursor:pointer;transition:all .15s;margin-top:4px}
.new-proj-btn:hover{background:rgba(0,255,136,.14);border-style:solid}

/* ── Main ── */
.main{padding:32px 28px;display:flex;flex-direction:column;gap:20px;min-width:0}

/* ── Page header ── */
.page-hdr{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap}
.page-title{font-family:var(--display);font-size:1.3rem;font-weight:800;color:#fff}
.page-sub{font-size:.62rem;color:var(--muted);margin-top:3px}
.hdr-btns{display:flex;gap:8px;flex-shrink:0}

/* ── Cards ── */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:18px}
.card-label{font-size:.55rem;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:.14em;margin-bottom:12px;display:flex;align-items:center;gap:6px}
.card-label::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--accent);box-shadow:0 0 5px var(--accent);flex-shrink:0}

/* ── Stats row ── */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.stat{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:14px 16px}
.stat .v{font-family:var(--display);font-size:1.3rem;font-weight:600;color:var(--accent);line-height:1}
.stat .v.blue{color:var(--blue)}
.stat .v.orange{color:var(--orange)}
.stat .v.purple{color:var(--purple)}
.stat .l{font-size:.52rem;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-top:4px}

/* ── Inputs ── */
input,textarea,select{font-family:var(--mono);background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:9px 12px;font-size:11.5px;color:var(--text);outline:none;transition:border-color .2s,box-shadow .2s;width:100%}
input:focus,textarea:focus,select:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-dim)}
input::placeholder,textarea::placeholder{color:var(--muted2)}
textarea{resize:vertical;line-height:1.7}

/* ── Buttons ── */
.btn{font-family:var(--mono);font-size:.65rem;border-radius:7px;padding:8px 16px;cursor:pointer;transition:all .15s;border:1px solid transparent;white-space:nowrap;font-weight:700}
.btn-primary{background:var(--accent);color:#000;box-shadow:0 0 16px var(--accent-dim)}
.btn-primary:hover{background:#33ffaa;box-shadow:0 0 24px var(--accent-glow)}
.btn-primary:disabled{background:var(--muted2);color:var(--bg);cursor:not-allowed;box-shadow:none}
.btn-outline{background:none;border-color:var(--border);color:var(--muted)}
.btn-outline:hover{border-color:var(--border2);color:var(--text);background:var(--bg3)}
.btn-danger{background:none;border-color:transparent;color:var(--muted2)}
.btn-danger:hover{border-color:rgba(239,68,68,.3);color:var(--red);background:var(--red-dim)}
.btn-blue{background:var(--blue-dim);border-color:rgba(59,130,246,.25);color:var(--blue)}
.btn-blue:hover{background:rgba(59,130,246,.18)}

/* ── Project dashboard cards ── */
.proj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px}
.proj-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:16px;cursor:pointer;transition:all .18s;position:relative;overflow:hidden}
.proj-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--accent);opacity:0;transition:opacity .18s}
.proj-card:hover{border-color:var(--border2);background:var(--bg3)}
.proj-card:hover::before{opacity:1}
.proj-card-name{font-family:var(--display);font-size:.78rem;font-weight:600;color:#fff;margin-bottom:8px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.proj-card-meta{display:flex;gap:10px;flex-wrap:wrap}
.proj-chip{font-size:.52rem;padding:2px 7px;border-radius:4px;text-transform:uppercase;letter-spacing:.06em}
.chip-green{background:var(--accent-dim);color:var(--accent)}
.chip-blue{background:var(--blue-dim);color:var(--blue)}
.chip-orange{background:var(--orange-dim);color:var(--orange)}
.chip-gray{background:var(--bg4);color:var(--muted)}
.proj-card-date{font-size:.52rem;color:var(--muted2);margin-top:8px}
.proj-card-actions{position:absolute;top:10px;right:10px;opacity:0;transition:opacity .15s}
.proj-card:hover .proj-card-actions{opacity:1}

/* ── Link table ── */
.link-table{width:100%;border-collapse:collapse}
.link-table th{font-size:.52rem;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;padding:8px 12px;text-align:left;border-bottom:1px solid var(--border);font-weight:400}
.link-table td{padding:10px 12px;border-bottom:1px solid var(--border);vertical-align:middle}
.link-table tr:last-child td{border-bottom:none}
.link-table tr:hover td{background:var(--bg3)}
.link-short{color:var(--accent);font-weight:700;font-size:.75rem;text-decoration:none;white-space:nowrap}
.link-short:hover{text-decoration:underline}
.link-orig{font-size:.65rem;color:var(--muted);max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:block;text-decoration:none}
.link-orig:hover{color:var(--text)}
.verdict-badge{font-size:.5rem;padding:3px 8px;border-radius:4px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;white-space:nowrap}
.v-indexed{background:var(--accent-dim);color:var(--accent)}
.v-crawled{background:var(--blue-dim);color:var(--blue)}
.v-pending{background:var(--orange-dim);color:var(--orange)}
.v-error{background:var(--red-dim);color:var(--red)}
.hits-num{color:var(--accent);font-weight:700}
.hits-zero{color:var(--muted2)}

/* ── Log ── */
.idx-log{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px 12px;max-height:180px;overflow-y:auto;font-size:10.5px;line-height:1.9;display:none;margin-top:10px}
.idx-log::-webkit-scrollbar{width:3px}
.idx-log::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.log-ok{color:var(--accent)}.log-err{color:var(--red)}.log-info{color:var(--muted)}

/* ── Modal ── */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(4px);z-index:200;display:none;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:16px;padding:24px;width:100%;max-width:460px;animation:popIn .2s ease}
@keyframes popIn{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}
.modal-title{font-family:var(--display);font-size:.95rem;font-weight:700;color:#fff;margin-bottom:16px}
.modal-row{display:flex;gap:10px;margin-top:12px}

/* ── Empty ── */
.empty{text-align:center;padding:60px 20px;color:var(--muted2);font-size:.72rem;border:1px dashed var(--border);border-radius:var(--r)}
.empty-icon{font-size:2.2rem;margin-bottom:14px;opacity:.3}

/* ── Toast ── */
.toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--bg3);border:1px solid var(--border2);color:var(--text);font-family:var(--mono);font-size:.72rem;padding:10px 22px;border-radius:10px;pointer-events:none;opacity:0;transition:transform .24s ease,opacity .24s ease;z-index:999;white-space:nowrap;box-shadow:0 8px 32px rgba(0,0,0,.5)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.toast.green{border-color:rgba(0,255,136,.35);color:var(--accent)}

/* ── View toggle ── */
.view{display:none}.view.active{display:flex;flex-direction:column;gap:20px;min-width:0}

/* ── Crawl Details Modal ── */
.crawl-modal{max-width:900px;width:100%}
.crawl-modal .modal-title{display:flex;align-items:center;gap:10px;margin-bottom:0}
.crawl-body-layout{display:grid;grid-template-columns:260px 1fr;gap:14px;align-items:start}
.crawl-preview-col{display:flex;flex-direction:column;gap:10px;position:sticky;top:0}
.crawl-preview-frame{background:var(--bg);border:1px solid var(--border);border-radius:10px;overflow:hidden}
.cpf-hdr{padding:7px 12px;font-size:.5rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:6px}
.cpf-img{width:100%;aspect-ratio:9/16;object-fit:cover;object-position:top;display:block;background:var(--bg3)}
.cpf-img-wrap{position:relative;overflow:hidden}
.cpf-img-wrap::after{content:'';position:absolute;bottom:0;left:0;right:0;height:40px;background:linear-gradient(transparent,var(--bg))}
.cpf-loading{width:100%;aspect-ratio:9/16;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;color:var(--muted2);font-size:.6rem}
.cpf-error{width:100%;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:6px;color:var(--muted2);font-size:.6rem;padding:20px;text-align:center}
.crawl-meta-mini{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:10px 12px;display:flex;flex-direction:column;gap:6px}
.cmm-row{display:flex;justify-content:space-between;align-items:center;gap:8px}
.cmm-k{font-size:.48rem;color:var(--muted);text-transform:uppercase;letter-spacing:.08em}
.cmm-v{font-size:.6rem;color:var(--text);font-weight:700}
.cmm-v.good{color:var(--accent)}
.cmm-v.bad{color:var(--red)}
.cmm-v.warn{color:var(--orange)}
.cmm-v.blue{color:var(--blue)}
.open-orig-btn{display:block;text-align:center;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:6px 10px;font-size:.55rem;color:var(--muted);text-decoration:none;transition:all .15s}
.open-orig-btn:hover{border-color:var(--accent);color:var(--accent)}
.crawl-url-bar{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:8px 12px;font-size:.65rem;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin:12px 0 16px}
.crawl-url-bar span{color:var(--accent)}
.crawl-sections{display:flex;flex-direction:column;gap:10px;max-height:480px;overflow-y:auto;padding-right:4px}
.crawl-sections::-webkit-scrollbar{width:3px}
.crawl-sections::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.crawl-section{background:var(--bg);border:1px solid var(--border);border-radius:10px;overflow:hidden}
.crawl-section-hdr{padding:9px 14px;font-size:.55rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;display:flex;align-items:center;gap:7px;border-bottom:1px solid var(--border)}
.crawl-section-hdr .cs-icon{font-size:.85rem}
.crawl-section-body{padding:10px 14px;display:grid;grid-template-columns:1fr 1fr;gap:6px 12px}
.crawl-section-body.single{grid-template-columns:1fr}
.crawl-kv{display:flex;flex-direction:column;gap:2px;padding:5px 0}
.crawl-kv .ck{font-size:.5rem;color:var(--muted);text-transform:uppercase;letter-spacing:.09em}
.crawl-kv .cv{font-size:.68rem;color:var(--text);word-break:break-all}
.crawl-kv .cv.good{color:var(--accent)}
.crawl-kv .cv.warn{color:var(--orange)}
.crawl-kv .cv.bad{color:var(--red)}
.crawl-kv .cv.blue{color:var(--blue)}
.crawl-loading{text-align:center;padding:40px 20px;color:var(--muted);font-size:.72rem}
.crawl-loading .spin{display:inline-block;animation:spin 1s linear infinite;font-size:1.4rem;margin-bottom:10px}
@keyframes spin{to{transform:rotate(360deg)}}
.crawl-error{background:var(--red-dim);border:1px solid rgba(239,68,68,.2);border-radius:8px;padding:12px 16px;font-size:.68rem;color:var(--red);margin:8px 0}
.crawl-verdict-banner{display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:10px;margin-bottom:4px}
.crawl-verdict-banner.pass{background:var(--accent-dim);border:1px solid rgba(0,255,136,.2)}
.crawl-verdict-banner.neutral{background:var(--blue-dim);border:1px solid rgba(59,130,246,.2)}
.crawl-verdict-banner.fail{background:var(--red-dim);border:1px solid rgba(239,68,68,.2)}
.crawl-verdict-banner.pending{background:var(--orange-dim);border:1px solid rgba(245,158,11,.2)}
.cvb-icon{font-size:1.5rem}
.cvb-label{font-family:var(--display);font-size:.85rem;font-weight:700}
.cvb-label.pass{color:var(--accent)}
.cvb-label.neutral{color:var(--blue)}
.cvb-label.fail{color:var(--red)}
.cvb-label.pending{color:var(--orange)}
.cvb-sub{font-size:.58rem;color:var(--muted);margin-top:2px}
.crawl-no-sa{text-align:center;padding:30px 20px;color:var(--muted2);font-size:.68rem}
.crawl-no-sa .ns-icon{font-size:2rem;margin-bottom:10px;opacity:.4}
.crawl-inspect-btn{background:var(--blue-dim);border:1px solid rgba(59,130,246,.25);color:var(--blue);font-family:var(--mono);font-size:.6rem;border-radius:6px;padding:3px 9px;cursor:pointer;transition:all .15s;white-space:nowrap}
.crawl-inspect-btn:hover{background:rgba(59,130,246,.18)}

/* ── Channel Cards ── */
.channel-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:12px}
.channel-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:16px;transition:border-color .2s}
.channel-card.active-ch{border-color:rgba(0,255,136,.3)}
.ch-hdr{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.ch-icon{font-size:1.2rem;flex-shrink:0}
.ch-title{font-family:var(--display);font-size:.72rem;font-weight:700;color:#fff;flex:1}
.ch-badge{font-size:.48rem;padding:2px 6px;border-radius:4px;text-transform:uppercase;letter-spacing:.06em}
.badge-white{background:var(--accent-dim);color:var(--accent)}
.badge-grey{background:var(--orange-dim);color:var(--orange)}
.badge-black{background:var(--red-dim);color:var(--red)}
.ch-desc{font-size:.58rem;color:var(--muted);line-height:1.6;margin-bottom:10px}
.ch-toggle{display:flex;align-items:center;gap:8px;font-size:.6rem;color:var(--muted);cursor:pointer;user-select:none}
.ch-toggle input[type=checkbox]{width:14px;height:14px;accent-color:var(--accent);cursor:pointer}

/* ── SA Vault ── */
.sa-vault-list{display:flex;flex-direction:column;gap:8px;margin-top:10px}
.sa-vault-item{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px 12px;display:flex;align-items:center;gap:10px}
.sa-vault-label{flex:1;font-size:.65rem;color:var(--text)}
.sa-vault-quota{font-size:.58rem;color:var(--muted)}
.sa-vault-quota.warn{color:var(--orange)}
.sa-vault-quota.full{color:var(--red)}
.sa-add-row{display:flex;gap:8px;margin-top:8px}

/* ── Escalation ── */
.esc-ladder{display:flex;flex-direction:column;gap:8px;margin-top:10px}
.esc-rung{display:flex;align-items:flex-start;gap:12px;padding:10px 14px;background:var(--bg);border:1px solid var(--border);border-radius:8px}
.esc-num{width:22px;height:22px;border-radius:50%;background:var(--bg4);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:700;color:var(--muted);flex-shrink:0}
.esc-info{flex:1}
.esc-title{font-size:.65rem;color:var(--text);font-weight:700}
.esc-sub{font-size:.55rem;color:var(--muted);margin-top:2px}

/* ── Social share panel ── */
.social-share-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;margin-top:10px}
.social-card{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:12px}
.social-card-title{font-size:.6rem;font-weight:700;color:var(--text);margin-bottom:6px;display:flex;align-items:center;gap:6px}
.social-card textarea{font-size:.55rem;height:70px;resize:none}
.social-btn-row{display:flex;gap:6px;margin-top:6px}

/* ── Domain checklist ── */
.domain-check{display:flex;flex-direction:column;gap:6px;margin-top:10px}
.domain-check-item{display:flex;align-items:center;gap:8px;font-size:.62rem;color:var(--muted);cursor:pointer;user-select:none}
.domain-check-item input[type=checkbox]{width:14px;height:14px;accent-color:var(--accent);cursor:pointer}
.domain-check-item.done{color:var(--accent)}

/* ── Ping blast log ── */
.ping-result{font-size:.55rem;line-height:1.9;color:var(--muted);margin-top:8px;max-height:140px;overflow-y:auto}

/* ── Settings tab ── */
.settings-section{margin-bottom:20px}
.settings-section-title{font-size:.58rem;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:.12em;margin-bottom:10px;display:flex;align-items:center;gap:6px}
.settings-section-title::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--accent)}
.hint{font-size:.55rem;color:var(--muted);margin-top:6px;line-height:1.6}

/* ── Retry count badge ── */
.retry-badge{font-size:.48rem;padding:1px 5px;border-radius:3px;background:var(--orange-dim);color:var(--orange);margin-left:4px}

/* ── Progress bar ── */
.prog-wrap{background:var(--bg);border-radius:4px;height:4px;width:100%;margin:8px 0;overflow:hidden;display:none}
.prog-bar{height:100%;background:var(--accent);border-radius:4px;transition:width .3s;width:0}

/* ── Tab bar inside indexing view ── */
.idx-tabs{display:flex;gap:4px;margin-bottom:16px;border-bottom:1px solid var(--border);padding-bottom:0}
.idx-tab{font-family:var(--mono);font-size:.62rem;padding:7px 14px;cursor:pointer;border:none;background:none;color:var(--muted);border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .15s}
.idx-tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.idx-tab:hover{color:var(--text)}
.idx-pane{display:none}.idx-pane.active{display:block}

/* ── Googlebot Feed Footer ── */
.bot-footer{position:fixed;bottom:0;left:260px;right:0;z-index:100;background:rgba(9,9,11,0.92);backdrop-filter:blur(10px);border-top:1px solid var(--border);display:flex;align-items:center;gap:0;height:36px;overflow:hidden}
.bot-footer-label{display:flex;align-items:center;gap:7px;padding:0 14px;border-right:1px solid var(--border);height:100%;flex-shrink:0;white-space:nowrap}
.bot-footer-label .bfl-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);box-shadow:0 0 6px var(--accent);animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.bot-footer-label span{font-size:.5rem;color:var(--muted);text-transform:uppercase;letter-spacing:.1em}
.bot-feed-track{flex:1;overflow:hidden;position:relative;height:100%}
.bot-feed-inner{display:flex;align-items:center;gap:0;height:100%;position:absolute;white-space:nowrap;will-change:transform}
.bot-feed-inner.paused{animation-play-state:paused!important}
.bot-event{display:inline-flex;align-items:center;gap:7px;padding:0 20px;height:100%;border-right:1px solid var(--border);flex-shrink:0;cursor:default;transition:background .15s}
.bot-event:hover{background:var(--bg3)}
.bot-event .be-icon{font-size:.75rem;flex-shrink:0}
.bot-event .be-time{font-size:.5rem;color:var(--muted2);flex-shrink:0}
.bot-event .be-proj{font-size:.52rem;color:var(--purple);flex-shrink:0}
.bot-event .be-code{font-size:.58rem;color:var(--accent);font-weight:700;flex-shrink:0}
.bot-event .be-sep{color:var(--muted2);font-size:.5rem}
.bot-event .be-hits{font-size:.5rem;color:var(--orange)}
.bot-empty-feed{font-size:.55rem;color:var(--muted2);padding:0 20px;display:flex;align-items:center;gap:6px;height:100%}
.bot-footer-refresh{padding:0 12px;height:100%;border-left:1px solid var(--border);background:none;cursor:pointer;font-size:.6rem;color:var(--muted);font-family:var(--mono);transition:color .15s;flex-shrink:0;border-right:none;border-top:none;border-bottom:none}
.bot-footer-refresh:hover{color:var(--accent)}
/* Push main content up so footer doesn't overlap */
.main{padding-bottom:52px}
@keyframes scrollFeed{from{transform:translateX(0)}to{transform:translateX(-50%)}}
</style>
</head>
<body>

<div class="app">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="brand">
      <div class="brand-logo">⚡</div>
      <div>
        <div class="brand-name">LinkCore</div>
        <div class="brand-sub">Backlink Manager</div>
      </div>
    </div>

    <div class="sb-label">Views</div>
    <button class="sb-btn active" onclick="showView(&#39;dashboard&#39;)">
      <span class="dot"></span> Dashboard
    </button>
    <button class="sb-btn" onclick="showView(&#39;indexing&#39;)">
      <span class="dot"></span> Submit to Google
    </button>
    <button class="sb-btn" onclick="showView(&#39;settings&#39;)">
      <span class="dot"></span> Settings &amp; Keys
    </button>

    <div class="sb-label" style="margin-top:12px">Projects</div>
    <div id="proj-list-sb"></div>
    <button class="new-proj-btn" onclick="openNewProj()">+ New Project</button>

    <div style="margin-top:auto;padding-top:16px;border-top:1px solid var(--border)">
      <div style="font-size:.52rem;color:var(--muted2)">Supabase</div>
      <div style="font-size:.65rem;color:var(--muted)" id="sb-status">Offline</div>
    </div>
  </aside>

  <!-- Main -->
  <main class="main">

    <!-- ── DASHBOARD VIEW ── -->
    <div class="view active" id="view-dashboard">
      <div class="page-hdr">
        <div>
          <div class="page-title">Projects</div>
          <div class="page-sub">All your backlink campaigns in one place</div>
        </div>
        <div class="hdr-btns">
          <button class="btn btn-primary" onclick="openNewProj()">+ New Project</button>
        </div>
      </div>

      <div class="stats">
        <div class="stat"><div class="v" id="st-projects">0</div><div class="l">Projects</div></div>
        <div class="stat"><div class="v blue" id="st-links">0</div><div class="l">Total Links</div></div>
        <div class="stat"><div class="v orange" id="st-hits">0</div><div class="l">Total Hits</div></div>
        <div class="stat"><div class="v purple" id="st-indexed">0</div><div class="l">Indexed</div></div>
      </div>

      <div id="proj-grid-wrap">
        <div class="empty" id="proj-empty">
          <div class="empty-icon">📁</div>
          <p>No projects yet.<br>Create your first backlink campaign.</p>
        </div>
        <div class="proj-grid" id="proj-grid" style="display:none"></div>
      </div>
    </div>

    <!-- ── PROJECT VIEW ── -->
    <div class="view" id="view-project">
      <div class="page-hdr">
        <div>
          <div class="page-title" id="proj-title">Project</div>
          <div class="page-sub" id="proj-sub">0 links</div>
        </div>
        <div class="hdr-btns">
          <button class="btn btn-outline" onclick="showView(&#39;dashboard&#39;)">← Back</button>
          <button class="btn btn-blue" onclick="openSocialPush()">📣 Social Push</button>
          <button class="btn btn-blue" onclick="showView(&#39;indexing&#39;)">🚀 Submit to Google</button>
          <button class="btn btn-primary" onclick="openAddLinks()">+ Add Links</button>
        </div>
      </div>

      <!-- Link table -->
      <div class="card" style="padding:0;overflow:hidden">
        <div style="padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
          <span class="card-label" style="margin:0">Links &amp; Status</span>
          <div style="display:flex;gap:8px">
            <button class="btn btn-outline" style="font-size:.58rem;padding:5px 10px" onclick="refreshVerdicts()">↻ Refresh Status</button>
            <button class="btn btn-outline" style="font-size:.58rem;padding:5px 10px" onclick="exportProjCSV()">↓ CSV</button>
          </div>
        </div>
        <div style="overflow-x:auto">
          <table class="link-table">
            <thead>
              <tr>
                <th>Short Link</th>
                <th>Original Backlink</th>
                <th>Status</th>
                <th>Hits</th>
                <th>Added</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="link-tbody"></tbody>
          </table>
        </div>
        <div class="empty" id="link-empty" style="border:none;border-top:1px solid var(--border);border-radius:0;display:none">
          <div class="empty-icon">🔗</div>
          <p>No links yet — click <strong style="color:var(--accent)">Add Links</strong> to start.</p>
        </div>
      </div>

      <!-- Domain ownership checklist -->
      <div class="card" id="domain-own-card" style="display:none">
        <div class="card-label">🏠 Own This Domain? — Internal Link Checklist</div>
        <div style="font-size:.62rem;color:var(--muted);margin-bottom:8px">If you control the site where backlinks live, tick off these internal link additions. Google crawls homepages daily — a homepage link = indexed within hours.</div>
        <div class="domain-check" id="domain-checklist">
          <label class="domain-check-item"><input type="checkbox" onchange="checkDomainItem(this)"> Added internal link from <strong>Homepage</strong> to backlink pages</label>
          <label class="domain-check-item"><input type="checkbox" onchange="checkDomainItem(this)"> Added link from <strong>Category / Archive page</strong></label>
          <label class="domain-check-item"><input type="checkbox" onchange="checkDomainItem(this)"> Added to <strong>Recent Posts widget / sidebar</strong></label>
          <label class="domain-check-item"><input type="checkbox" onchange="checkDomainItem(this)"> Updated <strong>sitemap.xml lastmod</strong> timestamp</label>
          <label class="domain-check-item"><input type="checkbox" onchange="checkDomainItem(this)"> Added page to <strong>RSS / Atom feed</strong></label>
        </div>
        <div style="margin-top:10px;display:flex;align-items:center;gap:10px;font-size:.6rem;color:var(--muted)">
          <input type="checkbox" id="proj-own-domain" onchange="toggleDomainOwn()"> <label for="proj-own-domain">I own / control the site with these backlinks</label>
        </div>
      </div>

    </div><!-- end view-project -->

    <!-- ── INDEXING VIEW ── -->
    <div class="view" id="view-indexing">
      <div class="page-hdr">
        <div>
          <div class="page-title">🚀 Indexing Hub</div>
          <div class="page-sub">Multi-channel crawl signal blaster — GSC · IndexNow · Ping · Social · Paid</div>
        </div>
        <div class="hdr-btns">
          <button class="btn btn-outline" onclick="showView(&#39;dashboard&#39;)">← Back</button>
        </div>
      </div>

      <!-- Tab bar -->
      <div class="idx-tabs">
        <button class="idx-tab active" onclick="switchIdxTab(&#39;submit&#39;)">🚀 Submit</button>
        <button class="idx-tab" onclick="switchIdxTab(&#39;channels&#39;)">📡 Channels</button>
        <button class="idx-tab" onclick="switchIdxTab(&#39;social&#39;)">📣 Social Push</button>
        <button class="idx-tab" onclick="switchIdxTab(&#39;escalation&#39;)">🔁 Escalation</button>
        <button class="idx-tab" onclick="switchIdxTab(&#39;report&#39;)">📊 Report</button>
      </div>

      <!-- ── SUBMIT PANE ── -->
      <div class="idx-pane active" id="idx-pane-submit">

        <div class="card" style="margin-bottom:12px">
          <div class="card-label">Select Project</div>
          <select id="idx-proj-sel" onchange="updateIdxPreview()">
            <option value="">— Choose a project —</option>
          </select>
          <div style="margin-top:10px;font-size:.62rem;color:var(--muted)" id="idx-preview">Select a project to see how many short links will be submitted.</div>
          <div style="margin-top:12px;display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <button class="btn btn-primary" id="idx-btn" onclick="runIndexing()" style="flex:1;min-width:200px">🚀 Blast All Enabled Channels</button>
            <button class="btn btn-outline" style="font-size:.6rem" onclick="switchIdxTab(&#39;channels&#39;)">⚙ Configure Channels</button>
          </div>
          <div class="prog-wrap" id="idx-progress"><div class="prog-bar" id="idx-prog-bar"></div></div>
          <div class="idx-log" id="idx-log"></div>
        </div>

        <!-- Live Sitemap Status -->
        <div class="card">
          <div class="card-label">🗺 Live Sitemap — Auto-Updated on Every Link Add</div>
          <div style="font-size:.62rem;color:var(--muted);line-height:1.7;margin-bottom:10px">
            Every time you add a URL, its short link is instantly added to the in-memory sitemap and all crawl signals are fired automatically — Google + Bing ping, PubSubHubbub, WebSub.
            Your Vercel Edge Function should serve the dynamic sitemap from Supabase at <span style="color:var(--accent)">https://tinubunews.com.ng/sitemap.xml</span>.
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px">
            <button class="btn btn-outline" style="font-size:.6rem" onclick="viewSitemap()">👁 Preview Sitemap XML</button>
            <button class="btn btn-outline" style="font-size:.6rem" onclick="manualSitemapPing()">📡 Manual Sitemap Ping</button>
          </div>
          <div class="idx-log" id="sitemap-log" style="max-height:120px"></div>
        </div>

        <!-- Active SA status -->
        <div class="card">
          <div class="card-label">Service Account Status</div>
          <div id="sa-status-display" style="font-size:.62rem;color:var(--muted)"><span style="color:var(--orange)">⚠ No SA keys configured — <a href="#" onclick="showView(&#39;settings&#39;);return false" style="color:var(--accent)">add keys in Settings</a></span></div>
          <div style="margin-top:10px">
            <button class="btn btn-outline" style="font-size:.6rem" onclick="showView(&#39;settings&#39;)">🔑 Manage SA Keys → Settings</button>
          </div>
        </div>
      </div>

      <!-- ── CHANNELS PANE ── -->
      <div class="idx-pane" id="idx-pane-channels">
        <div class="channel-grid">

          <!-- GSC URL Inspection -->
          <div class="channel-card" id="ch-gsc">
            <div class="ch-hdr">
              <span class="ch-icon">🔍</span>
              <span class="ch-title">GSC URL Inspection</span>
              <span class="ch-badge badge-white">WHITEHAT</span>
            </div>
            <div class="ch-desc">Direct Google signal. Inspects &amp; submits each URL. Auto-rotates across your SA keys to bypass 200/day quota per key.</div>
            <label class="ch-toggle"><input type="checkbox" id="ch-gsc-on" checked="" onchange="saveChanSettings()"> Enable</label>
          </div>

          <!-- Google Indexing API -->
          <div class="channel-card" id="ch-idx-api">
            <div class="ch-hdr">
              <span class="ch-icon">⚡</span>
              <span class="ch-title">Google Indexing API</span>
              <span class="ch-badge badge-grey">GREY-LOW</span>
            </div>
            <div class="ch-desc">Fastest known crawl trigger. Uses URL_UPDATED signal. Runs alongside URL Inspection (different OAuth scope) — doubles your quota per SA key.</div>
            <label class="ch-toggle"><input type="checkbox" id="ch-idx-api-on" checked="" onchange="saveChanSettings()"> Enable</label>
          </div>

          <!-- GSC Sitemaps API -->
          <div class="channel-card" id="ch-sitemap-api">
            <div class="ch-hdr">
              <span class="ch-icon">🗺</span>
              <span class="ch-title">GSC Sitemaps API</span>
              <span class="ch-badge badge-white">WHITEHAT</span>
            </div>
            <div class="ch-desc">Programmatically DELETE then RE-ADD your sitemap, forcing Google to re-scan from scratch. Much stronger than a ping.</div>
            <label class="ch-toggle"><input type="checkbox" id="ch-sitemap-api-on" checked="" onchange="saveChanSettings()"> Enable</label>
          </div>

          <!-- IndexNow Multi-Engine -->
          <div class="channel-card">
            <div class="ch-hdr">
              <span class="ch-icon">📡</span>
              <span class="ch-title">IndexNow Multi-Engine</span>
              <span class="ch-badge badge-white">WHITEHAT</span>
            </div>
            <div class="ch-desc">Blasts ALL IndexNow endpoints simultaneously: Bing, Yandex, Seznam, Naver, Yep, indexnow.org — faster than hitting one.</div>
            <label class="ch-toggle"><input type="checkbox" id="ch-indexnow-on" checked="" onchange="saveChanSettings()"> Enable</label>
          </div>

          <!-- Bing Webmaster Direct -->
          <div class="channel-card">
            <div class="ch-hdr">
              <span class="ch-icon">🔎</span>
              <span class="ch-title">Bing Webmaster API</span>
              <span class="ch-badge badge-white">WHITEHAT</span>
            </div>
            <div class="ch-desc">Direct Bing URL submission — 10,000/day free. Separate from IndexNow. Bing shares crawl signals with Yahoo and DuckDuckGo.</div>
            <div style="margin-top:8px">
              <input id="bing-api-key" placeholder="Bing Webmaster API Key" style="margin-bottom:6px" oninput="saveChanSettings()">
            </div>
            <label class="ch-toggle"><input type="checkbox" id="ch-bing-on" onchange="saveChanSettings()"> Enable</label>
          </div>

          <!-- PubSubHubbub + WebSub -->
          <div class="channel-card">
            <div class="ch-hdr">
              <span class="ch-icon">📢</span>
              <span class="ch-title">PubSub + WebSub Triple-Fire</span>
              <span class="ch-badge badge-white">WHITEHAT</span>
            </div>
            <div class="ch-desc">Indexing API + PubSubHubbub + WebSub simultaneously. Same system news publishers use. Queues an immediate crawl in Google's internal pipeline.</div>
            <label class="ch-toggle"><input type="checkbox" id="ch-pubsub-on" checked="" onchange="saveChanSettings()"> Enable</label>
          </div>

          <!-- XML-RPC Ping Blast -->
          <div class="channel-card">
            <div class="ch-hdr">
              <span class="ch-icon">💥</span>
              <span class="ch-title">XML-RPC Ping Blast</span>
              <span class="ch-badge badge-grey">GREY-LOW</span>
            </div>
            <div class="ch-desc">Hits 20+ ping services simultaneously: Pingomatic, Weblogs.com, ping.blo.gs, FeedBurner, Technorati, Yandex Blog ping — all at once.</div>
            <label class="ch-toggle"><input type="checkbox" id="ch-xmlrpc-on" checked="" onchange="saveChanSettings()"> Enable</label>
          </div>

          <!-- Rapid URL Indexer -->
          <div class="channel-card">
            <div class="ch-hdr">
              <span class="ch-icon">🌀</span>
              <span class="ch-title">Rapid URL Indexer</span>
              <span class="ch-badge badge-grey">GREY-LOW · PAID</span>
            </div>
            <div class="ch-desc">90%+ indexation rate. Fires through 200+ ping services + proprietary crawl networks. ~$0.01–0.03/URL. Best for stubborn NEUTRAL links.</div>
            <div style="margin-top:8px">
              <input id="rui-api-key" placeholder="Rapid URL Indexer API Key" style="margin-bottom:6px" oninput="saveChanSettings()">
            </div>
            <label class="ch-toggle"><input type="checkbox" id="ch-rui-on" onchange="saveChanSettings()"> Enable (fires on 2nd retry if NEUTRAL)</label>
          </div>

          <!-- Tier 2 Crawl Trigger -->
          <div class="channel-card">
            <div class="ch-hdr">
              <span class="ch-icon">🔗</span>
              <span class="ch-title">Tier 2 Link Trigger</span>
              <span class="ch-badge badge-grey">GREY-LOW</span>
            </div>
            <div class="ch-desc">After submitting, generates pre-filled social share drafts for Reddit/X/LinkedIn/Pinterest that link to pages containing your backlinks. See "Social Push" tab.</div>
            <label class="ch-toggle"><input type="checkbox" id="ch-t2-on" checked="" onchange="saveChanSettings()"> Auto-generate social drafts on submit</label>
          </div>

        </div>
      </div>

      <!-- ── SOCIAL PUSH PANE ── -->
      <div class="idx-pane" id="idx-pane-social">
        <div class="card">
          <div class="card-label">Social Share Drafts — Tier 2 Crawl Triggers</div>
          <div style="font-size:.62rem;color:var(--muted);margin-bottom:14px">Select a project, then generate pre-filled post drafts. Posting on Reddit/Pinterest/X gets Googlebot to visit those pages within minutes — Googlebot follows links from those pages to your backlinks.</div>
          <div style="display:flex;gap:10px;margin-bottom:14px">
            <select id="social-proj-sel" style="flex:1">
              <option value="">— Choose a project —</option>
            </select>
            <button class="btn btn-primary" onclick="generateSocialDrafts()">⚡ Generate Drafts</button>
          </div>
          <div id="social-drafts-output"></div>
        </div>
      </div>

      <!-- ── ESCALATION PANE ── -->
      <div class="idx-pane" id="idx-pane-escalation">
        <div class="card" style="margin-bottom:12px">
          <div class="card-label">Smart Escalation Ladder</div>
          <div style="font-size:.62rem;color:var(--muted);margin-bottom:14px">Links stuck as NEUTRAL get automatically escalated. Each retry fires a more aggressive channel combo.</div>
          <div class="esc-ladder">
            <div class="esc-rung"><div class="esc-num">1</div><div class="esc-info"><div class="esc-title">First Submit</div><div class="esc-sub">GSC URL Inspection + Google Indexing API + IndexNow all endpoints + PubSub triple-fire</div></div></div>
            <div class="esc-rung"><div class="esc-num">2</div><div class="esc-info"><div class="esc-title">48h Retry (NEUTRAL)</div><div class="esc-sub">All above + XML-RPC ping blast + GSC Sitemaps API re-add + Bing Webmaster direct + Rapid URL Indexer (if key set)</div></div></div>
            <div class="esc-rung"><div class="esc-num">3</div><div class="esc-info"><div class="esc-title">72h Retry (still NEUTRAL)</div><div class="esc-sub">All above + auto-generate social share drafts (Reddit/Pinterest/X/LinkedIn)</div></div></div>
            <div class="esc-rung"><div class="esc-num">4</div><div class="esc-info"><div class="esc-title" style="color:var(--orange)">96h — Manual Review Flag</div><div class="esc-sub">All signals fired. URL flagged for manual inspection — may have structural issues (noindex, robots block, thin content)</div></div></div>
          </div>
        </div>

        <div class="card">
          <div class="card-label">Run Escalation Now — NEUTRAL Links</div>
          <div style="font-size:.62rem;color:var(--muted);margin-bottom:12px">Finds all NEUTRAL links across all projects and fires the appropriate escalation tier based on their retry count.</div>
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <select id="esc-proj-sel" style="flex:1;min-width:180px">
              <option value="all">All Projects</option>
            </select>
            <button class="btn btn-primary" onclick="runEscalation()">🔁 Run Escalation</button>
          </div>
          <div class="idx-log" id="esc-log" style="margin-top:10px"></div>
        </div>
      </div>

      <!-- ── REPORT PANE ── -->
      <div class="idx-pane" id="idx-pane-report">
        <div class="card">
          <div class="card-label">Fetch Report — All Projects</div>
          <div style="overflow-x:auto">
            <table class="link-table" id="report-table">
              <thead>
                <tr>
                  <th>Project</th>
                  <th>Short Link</th>
                  <th>Original URL</th>
                  <th>GSC Status</th>
                  <th>Hits 🤖</th>
                  <th>Retries</th>
                  <th>Submitted</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="report-tbody"></tbody>
            </table>
          </div>
          <div class="empty" id="report-empty" style="border:none;border-top:1px solid var(--border);border-radius:0">
            <div class="empty-icon">📊</div>
            <p>Submit links to see fetch reports here.</p>
          </div>
        </div>
      </div>

    </div><!-- end view-indexing -->

    <!-- ── SETTINGS VIEW ── -->
    <div class="view" id="view-settings">
      <div class="page-hdr">
        <div>
          <div class="page-title">⚙ Settings &amp; API Keys</div>
          <div class="page-sub">Service Account vault, GSC property, and crawl configuration</div>
        </div>
        <div class="hdr-btns">
          <button class="btn btn-outline" onclick="showView(&#39;dashboard&#39;)">← Back</button>
        </div>
      </div>

      <!-- SA Vault -->
      <div class="card" style="margin-bottom:12px">
        <div class="card-label">🔑 Service Account Key Vault</div>
        <div style="font-size:.62rem;color:var(--muted);margin-bottom:12px">Add multiple SA keys. LinkCore auto-rotates keys when one hits its 200/day quota — 10 keys = 2,000 submissions/day.</div>

        <div class="sa-vault-list" id="sa-vault-list"><div style="font-size:.6rem;color:var(--muted2);padding:8px 0">No SA keys yet — add your first one below.</div></div>

        <div class="sa-add-row">
          <textarea id="sa-new-json" rows="3" placeholder="{&quot;type&quot;:&quot;service_account&quot;,&quot;project_id&quot;:&quot;...&quot;,&quot;private_key&quot;:&quot;...&quot;,&quot;client_email&quot;:&quot;...&quot;}"></textarea>
          <button class="btn btn-primary" style="align-self:flex-end;white-space:nowrap" onclick="addSAKey()">+ Add Key</button>
        </div>

