<div class="toast" id="toast"></div>

<script>
// ══════════════════════════════════════════════════════════
// LinkCore v6 — Full JS Engine
// ══════════════════════════════════════════════════════════

// ── Config ────────────────────────────────────────────────
const SHORT_BASE       = 'https://tinubunews.com.ng/link/';
const SITEMAP_URL      = 'https://tinubunews.com.ng/sitemap.xml';
const FEED_URL         = 'https://tinubunews.com.ng/feed.xml';
const INDEXNOW_KEY     = 'indexcore';
const INDEXNOW_KEY_LOC = 'https://tinubunews.com.ng/indexcore.txt';
const SB_URL           = 'https://rbqfmhyuzdizaexbfcem.supabase.co';
const SB_KEY           = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJicWZtaHl1emRpemFleGJmY2VtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ1NDQwOTIsImV4cCI6MjA5MDEyMDA5Mn0.jXYe6qqqc5NCxvMPVVhiGqMYXfyiQ92bj5eCQt2J4WM';
const H                = {'apikey':SB_KEY,'Authorization':`Bearer ${SB_KEY}`,'Content-Type':'application/json'};

// ── State ─────────────────────────────────────────────────
let projects   = [];
let links      = {};
let activeProj = null;
let saVault    = [];   // [{label,json,daily_used,date}]
let chanSettings = {
  gsc:true, idxApi:true, sitemapApi:true, indexnow:true,
  bing:false, pubsub:true, xmlrpc:true, rui:false, t2:true
};

// ── Boot ──────────────────────────────────────────────────
window.addEventListener('load', async () => {
  restoreSettings();
  await loadAll();
  refreshBotFeed();
  renderSAVault();
  renderSAStatus();
});

// ══════════════════════════════════════════════════════════
// SETTINGS PERSIST
// ══════════════════════════════════════════════════════════
function restoreSettings(){
  try{
    const v = JSON.parse(localStorage.getItem('lc_sa_vault')||'[]');
    saVault = Array.isArray(v) ? v : [];
    const c = JSON.parse(localStorage.getItem('lc_chan')||'null');
    if(c) chanSettings = {...chanSettings,...c};
    const site = localStorage.getItem('lc_gsc_site');
    if(site){ const el=document.getElementById('gsc-site'); if(el) el.value=site; }
    const bk = localStorage.getItem('lc_bing_key');
    if(bk){ const el=document.getElementById('bing-api-key'); if(el) el.value=bk; }
    const rk = localStorage.getItem('lc_rui_key');
    if(rk){ const el=document.getElementById('rui-api-key'); if(el) el.value=rk; }
    // Restore channel toggles
    Object.keys(chanSettings).forEach(k=>{
      const el = document.getElementById(`ch-${k.replace(/([A-Z])/g,'-$1').toLowerCase()}-on`);
      if(el) el.checked = chanSettings[k];
    });
  }catch(e){}
}
function saveGscSettings(){
  try{ localStorage.setItem('lc_gsc_site', document.getElementById('gsc-site').value); }catch(e){}
}
function saveChanSettings(){
  chanSettings.gsc        = document.getElementById('ch-gsc-on')?.checked??true;
  chanSettings.idxApi     = document.getElementById('ch-idx-api-on')?.checked??true;
  chanSettings.sitemapApi = document.getElementById('ch-sitemap-api-on')?.checked??true;
  chanSettings.indexnow   = document.getElementById('ch-indexnow-on')?.checked??true;
  chanSettings.bing       = document.getElementById('ch-bing-on')?.checked??false;
  chanSettings.pubsub     = document.getElementById('ch-pubsub-on')?.checked??true;
  chanSettings.xmlrpc     = document.getElementById('ch-xmlrpc-on')?.checked??true;
  chanSettings.rui        = document.getElementById('ch-rui-on')?.checked??false;
  chanSettings.t2         = document.getElementById('ch-t2-on')?.checked??true;
  try{
    localStorage.setItem('lc_chan', JSON.stringify(chanSettings));
    localStorage.setItem('lc_bing_key', document.getElementById('bing-api-key')?.value||'');
    localStorage.setItem('lc_rui_key', document.getElementById('rui-api-key')?.value||'');
  }catch(e){}
}

// ══════════════════════════════════════════════════════════
// SA VAULT
// ══════════════════════════════════════════════════════════
function addSAKey(){
  const raw = document.getElementById('sa-new-json').value.trim();
  if(!raw){ toast('Paste a Service Account JSON first',''); return; }
  try{
    const sa = JSON.parse(raw);
    if(!sa.client_email||!sa.private_key) throw new Error('Missing fields');
    const label = sa.client_email.split('@')[0];
    const today = new Date().toDateString();
    saVault.push({label, json:raw, daily_used:0, date:today});
    localStorage.setItem('lc_sa_vault', JSON.stringify(saVault));
    document.getElementById('sa-new-json').value='';
    renderSAVault();
    renderSAStatus();
    toast(`🔑 SA key "${label}" added`,'green');
  }catch(e){ toast('Invalid JSON: '+e.message,''); }
}

function removeSAKey(i){
  saVault.splice(i,1);
  localStorage.setItem('lc_sa_vault', JSON.stringify(saVault));
  renderSAVault();
  renderSAStatus();
  toast('🗑 SA key removed','');
}

function renderSAVault(){
  const el = document.getElementById('sa-vault-list');
  if(!el) return;
  if(!saVault.length){
    el.innerHTML = `<div style="font-size:.6rem;color:var(--muted2);padding:8px 0">No SA keys yet — add your first one below.</div>`;
    return;
  }
  el.innerHTML = saVault.map((sa,i)=>{
    const today = new Date().toDateString();
    if(sa.date!==today){ sa.daily_used=0; sa.date=today; }
    const pct = Math.round((sa.daily_used/200)*100);
    const cls = pct>=100?'full':pct>=75?'warn':'';
    return `<div class="sa-vault-item">
      <div class="sa-vault-label">🔑 ${he(sa.label)}</div>
      <div class="sa-vault-quota ${cls}">${sa.daily_used}/200 today</div>
      <div style="width:60px;background:var(--bg3);border-radius:3px;height:4px;overflow:hidden">
        <div style="height:100%;width:${Math.min(pct,100)}%;background:${pct>=100?'var(--red)':pct>=75?'var(--orange)':'var(--accent)'}"></div>
      </div>
      <button class="btn btn-danger" style="font-size:.5rem;padding:2px 6px" onclick="removeSAKey(${i})">✕</button>
    </div>`;
  }).join('');
  localStorage.setItem('lc_sa_vault', JSON.stringify(saVault));
}

function renderSAStatus(){
  const el = document.getElementById('sa-status-display');
  if(!el) return;
  if(!saVault.length){
    el.innerHTML = `<span style="color:var(--orange)">⚠ No SA keys configured — <a href="#" onclick="showView('settings');return false" style="color:var(--accent)">add keys in Settings</a></span>`;
    return;
  }
  const today = new Date().toDateString();
  const active = saVault.filter(s=>{ if(s.date!==today) s.daily_used=0; return s.daily_used<200; });
  const totalCap = saVault.length * 200;
  const totalUsed = saVault.reduce((a,s)=>a+(s.daily_used||0),0);
  el.innerHTML = `<span style="color:var(--accent)">✓ ${saVault.length} SA key${saVault.length!==1?'s':''} loaded</span>
    &nbsp;·&nbsp; ${active.length} active today
    &nbsp;·&nbsp; <span style="color:var(--text)">${totalUsed}/${totalCap}</span> quota used
    &nbsp;·&nbsp; <span style="color:var(--blue)">${totalCap-totalUsed} submissions remaining today</span>`;
}

// Get next available SA key, rotating on quota
function getNextSA(){
  const today = new Date().toDateString();
  for(const sa of saVault){
    if(sa.date!==today){ sa.daily_used=0; sa.date=today; }
    if(sa.daily_used<200) return sa;
  }
  return null;
}

// ══════════════════════════════════════════════════════════
// VIEW SWITCHING
// ══════════════════════════════════════════════════════════
function showView(name, projId){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  const el = document.getElementById(`view-${name}`);
  if(el) el.classList.add('active');
  document.querySelectorAll('.sb-btn').forEach(b=>b.classList.remove('active'));
  const match = document.querySelector(`.sb-btn[onclick*="${name}"]`);
  if(match) match.classList.add('active');
  if(name==='indexing'){
    renderIndexingView();
    renderReport();
    renderSAStatus();
    populateEscSel();
  }
  if(name==='project' && projId){
    activeProj = projId;
    renderProjectView(projId);
    document.getElementById('domain-own-card').style.display = '';
  }
  if(name==='settings'){ renderSAVault(); renderSAStatus(); }
}

function switchIdxTab(tab){
  document.querySelectorAll('.idx-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.idx-pane').forEach(p=>p.classList.remove('active'));
  document.querySelector(`.idx-tab[onclick*="${tab}"]`)?.classList.add('active');
  document.getElementById(`idx-pane-${tab}`)?.classList.add('active');
  if(tab==='social') populateSocialSel();
  if(tab==='report') renderReport();
}

// ══════════════════════════════════════════════════════════
// SUPABASE HELPERS
// ══════════════════════════════════════════════════════════
async function sbGet(path){
  const r = await fetch(`${SB_URL}/rest/v1/${path}`,{headers:H});
  return r.ok ? r.json() : [];
}
async function sbPost(table,data,prefer='resolution=merge-duplicates'){
  return fetch(`${SB_URL}/rest/v1/${table}`,{method:'POST',headers:{...H,'Prefer':prefer},body:JSON.stringify(data)});
}
async function sbPatch(table,filter,data){
  return fetch(`${SB_URL}/rest/v1/${table}?${filter}`,{method:'PATCH',headers:{...H,'Prefer':'return=minimal'},body:JSON.stringify(data)});
}
async function sbDelete(table,filter){
  return fetch(`${SB_URL}/rest/v1/${table}?${filter}`,{method:'DELETE',headers:H});
}

function uid(){ return Date.now().toString(36)+Math.random().toString(36).slice(2,7); }
function genCode(){
  const c='abcdefghijklmnopqrstuvwxyz'; let code,t=0;
  do{ code=Array.from({length:5},()=>c[Math.floor(Math.random()*c.length)]).join(''); t++; }
  while(allCodes().includes(code)&&t<200); return code;
}
function allCodes(){ return Object.values(links).flat().map(l=>l.code); }

// ══════════════════════════════════════════════════════════
// LOAD ALL DATA
// ══════════════════════════════════════════════════════════
async function loadAll(){
  try{
    document.getElementById('sb-status').textContent='Loading…';
    const [projs, lnks] = await Promise.all([
      sbGet('lc_projects?order=created_at.asc'),
      sbGet('lc_links?order=added_at.asc')
    ]);
    projects = projs||[];
    links = {};
    projects.forEach(p=>{ links[p.id]=[]; });
    (lnks||[]).forEach(l=>{ if(links[l.project_id]) links[l.project_id].push(l); });

    const shortRows = await sbGet('ic_short_links?select=code,hits');
    const hitsMap = {};
    (shortRows||[]).forEach(r=>{ hitsMap[r.code]=r.hits||0; });
    Object.values(links).flat().forEach(l=>{ if(hitsMap[l.code]!==undefined) l.hits=hitsMap[l.code]; });

    document.getElementById('sb-status').textContent='Connected ✓';
    renderAll();
  }catch(e){
    document.getElementById('sb-status').textContent='Offline';
  }
}

function renderAll(){
  renderSidebar();
  renderDashboard();
  renderIndexingView();
  renderReport();
  populateEscSel();
  populateSocialSel();
  if(activeProj) renderProjectView(activeProj);
}

// ══════════════════════════════════════════════════════════
// RENDER
// ══════════════════════════════════════════════════════════
function renderSidebar(){
  const el = document.getElementById('proj-list-sb');
  el.innerHTML = projects.map(p=>{
    const cnt = (links[p.id]||[]).length;
    return `<button class="sb-btn${activeProj===p.id?' active':''}" onclick="showView('project','${p.id}')">
      <span class="dot"></span>
      <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;text-align:left">${he(p.name)}</span>
      <span class="cnt">${cnt}</span>
    </button>`;
  }).join('');
}

function renderDashboard(){
  const allLinks  = Object.values(links).flat();
  const totalHits = allLinks.reduce((a,l)=>a+(l.hits||0),0);
  const indexed   = allLinks.filter(l=>l.verdict==='PASS'||l.verdict==='indexed').length;
  document.getElementById('st-projects').textContent = projects.length;
  document.getElementById('st-links').textContent    = allLinks.length;
  document.getElementById('st-hits').textContent     = totalHits;
  document.getElementById('st-indexed').textContent  = indexed;

  const empty = document.getElementById('proj-empty');
  const grid  = document.getElementById('proj-grid');
  if(!projects.length){ empty.style.display=''; grid.style.display='none'; return; }
  empty.style.display='none'; grid.style.display='grid';

  grid.innerHTML = projects.map(p=>{
    const pl   = links[p.id]||[];
    const hits = pl.reduce((a,l)=>a+(l.hits||0),0);
    const idx  = pl.filter(l=>l.verdict==='PASS'||l.verdict==='indexed').length;
    const date = new Date(p.created_at).toLocaleDateString();
    return `<div class="proj-card" onclick="showView('project','${p.id}')">
      <div class="proj-card-actions">
        <button class="btn btn-danger" style="font-size:.55rem;padding:3px 7px" onclick="event.stopPropagation();deleteProject('${p.id}')">✕</button>
      </div>
      <div class="proj-card-name">${he(p.name)}</div>
      <div class="proj-card-meta">
        <span class="proj-chip chip-green">${pl.length} links</span>
        <span class="proj-chip chip-orange">${hits} hits</span>
        ${idx?`<span class="proj-chip chip-blue">${idx} indexed</span>`:''}
      </div>
      <div class="proj-card-date">Created ${date}</div>
    </div>`;
  }).join('');
}

function renderProjectView(projId){
  const p  = projects.find(x=>x.id===projId);
  if(!p) return;
  const pl = links[projId]||[];
  document.getElementById('proj-title').textContent = p.name;
  document.getElementById('proj-sub').textContent   = `${pl.length} link${pl.length!==1?'s':''}`;

  const tbody = document.getElementById('link-tbody');
  const empty = document.getElementById('link-empty');

  if(!pl.length){ tbody.innerHTML=''; empty.style.display=''; return; }
  empty.style.display='none';

  tbody.innerHTML = pl.map(l=>{
    const shortUrl  = SHORT_BASE+l.code;
    const origDisp  = l.original.replace(/^https?:\/\//,'').slice(0,45);
    const hits      = l.hits||0;
    const verdict   = verdictBadge(l.verdict);
    const date      = new Date(l.added_at).toLocaleDateString();
    const retries   = l.retry_count ? `<span class="retry-badge">↻${l.retry_count}</span>` : '';
    return `<tr>
      <td><a class="link-short" href="${he(shortUrl)}" target="_blank">${he(shortUrl)}</a></td>
      <td><a class="link-orig" href="${he(l.original)}" target="_blank" title="${he(l.original)}">${he(origDisp)}${l.original.length>45?'…':''}</a></td>
      <td>${verdict}${retries}</td>
      <td><span class="${hits>0?'hits-num':'hits-zero'}">${hits}</span></td>
      <td style="color:var(--muted);font-size:.62rem">${date}</td>
      <td>
        <div style="display:flex;gap:6px">
          <button class="crawl-inspect-btn" onclick="openCrawlDetails('${he(shortUrl)}','${he(l.original)}')">🔍 Inspect</button>
          <button class="btn btn-outline" style="font-size:.55rem;padding:3px 8px" onclick="copyShort('${he(shortUrl)}',this)">COPY</button>
          <button class="btn btn-danger" style="font-size:.55rem;padding:3px 8px" onclick="deleteLink('${l.id}','${projId}')">✕</button>
        </div>
      </td>
    </tr>`;
  }).join('');
}

function verdictBadge(v){
  if(!v||v==='pending') return `<span class="verdict-badge v-pending">Pending</span>`;
  if(v==='PASS'||v==='indexed') return `<span class="verdict-badge v-indexed">Indexed</span>`;
  if(v==='NEUTRAL'||v==='crawled') return `<span class="verdict-badge v-crawled">Crawled</span>`;
  if(v==='FAIL'||v==='error') return `<span class="verdict-badge v-error">Error</span>`;
  return `<span class="verdict-badge v-pending">${v}</span>`;
}

function renderIndexingView(){
  const sel = document.getElementById('idx-proj-sel');
  if(!sel) return;
  const cur = sel.value;
  sel.innerHTML = '<option value="">— Choose a project —</option>'+
    projects.map(p=>`<option value="${p.id}">${he(p.name)} (${(links[p.id]||[]).length} links)</option>`).join('');
  if(cur) sel.value=cur;
  updateIdxPreview();
}

function updateIdxPreview(){
  const pid = document.getElementById('idx-proj-sel')?.value;
  const el  = document.getElementById('idx-preview');
  if(!el) return;
  if(!pid){ el.textContent='Select a project to see how many short links will be submitted.'; return; }
  const pl = links[pid]||[];
  const active = Object.entries(chanSettings).filter(([k,v])=>v&&k!=='t2').length;
  el.textContent = `${pl.length} short link${pl.length!==1?'s':''} will be blasted across ${active} active channel${active!==1?'s':''}.`;
}

function renderReport(){
  const tbody = document.getElementById('report-tbody');
  const empty = document.getElementById('report-empty');
  if(!tbody) return;
  const allLinks = Object.values(links).flat();
  const submitted = allLinks.filter(l=>l.submitted);
  if(!submitted.length){ tbody.innerHTML=''; empty.style.display=''; return; }
  empty.style.display='none';
  tbody.innerHTML = submitted.map(l=>{
    const p        = projects.find(x=>x.id===l.project_id)||{name:'—'};
    const shortUrl = SHORT_BASE+l.code;
    const origDisp = l.original.replace(/^https?:\/\//,'').slice(0,38);
    const hits     = l.hits||0;
    const retries  = l.retry_count||0;
    return `<tr>
      <td style="font-size:.65rem;color:var(--muted);white-space:nowrap">${he(p.name)}</td>
      <td><a class="link-short" href="${he(shortUrl)}" target="_blank" style="font-size:.72rem">${l.code}</a></td>
      <td><a class="link-orig" href="${he(l.original)}" target="_blank" title="${he(l.original)}">${he(origDisp)}…</a></td>
      <td>${verdictBadge(l.verdict)}</td>
      <td><span class="${hits>0?'hits-num':'hits-zero'}">${hits}${hits>0?' 🤖':''}</span></td>
      <td style="color:var(--muted);font-size:.62rem">${retries>0?`↻${retries}`:'—'}</td>
      <td style="color:${l.submitted?'var(--accent)':'var(--muted2)'};font-size:.62rem">${l.submitted?'✓':'—'}</td>
      <td><button class="crawl-inspect-btn" onclick="openCrawlDetails('${he(shortUrl)}','${he(l.original)}')">🔍 Inspect</button></td>
    </tr>`;
  }).join('');
}

function populateEscSel(){
  const sel = document.getElementById('esc-proj-sel');
  if(!sel) return;
  sel.innerHTML = '<option value="all">All Projects</option>'+
    projects.map(p=>`<option value="${p.id}">${he(p.name)}</option>`).join('');
}
