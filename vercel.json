// ══════════════════════════════════════════════════════════
// LINK CRUD
// ══════════════════════════════════════════════════════════
function openAddLinks(){
  document.getElementById('links-input').value='';
  document.getElementById('add-links-title').textContent = `Add Links — ${projects.find(p=>p.id===activeProj)?.name||''}`;
  document.getElementById('modal-links').classList.add('open');
  setTimeout(()=>document.getElementById('links-input').focus(),100);
}

async function addLinks(){
  const raw  = document.getElementById('links-input').value;
  const urls = raw.split('\n').map(u=>u.trim()).filter(u=>u.startsWith('http'));
  if(!urls.length){ toast('Paste at least one URL',''); return; }

  const existing = (links[activeProj]||[]).map(l=>l.original);
  const newUrls  = urls.filter(u=>!existing.includes(u));
  if(!newUrls.length){ toast('All URLs already in this project',''); closeModal('modal-links'); return; }

  const now = new Date().toISOString();
  const newLinks = newUrls.map(original=>({
    id: uid(), project_id: activeProj, original,
    code: genCode(), verdict:'pending', hits:0, submitted:false,
    retry_count:0, added_at: now
  }));

  // Save to Supabase
  await sbPost('lc_links', newLinks);
  await sbPost('ic_short_links', newLinks.map(l=>({code:l.code, target:l.original})));

  if(!links[activeProj]) links[activeProj]=[];
  links[activeProj].push(...newLinks);
  closeModal('modal-links');
  renderAll();
  toast(`✅ ${newLinks.length} short link${newLinks.length!==1?'s':''} created`,'green');

  // Auto: update in-memory sitemap and fire signals
  await autoSitemapAndSignal(newLinks.map(l=>SHORT_BASE+l.code));
}

async function deleteLink(id, projId){
  await sbDelete('lc_links',`id=eq.${id}`);
  links[projId] = (links[projId]||[]).filter(l=>l.id!==id);
  renderAll();
  toast('🗑 Link removed','');
}

// ══════════════════════════════════════════════════════════
// AUTO SITEMAP + SIGNAL ON NEW LINK
// ══════════════════════════════════════════════════════════
async function autoSitemapAndSignal(newShortUrls){
  // Build live sitemap XML from ALL current links
  const allUrls = Object.values(links).flat().map(l=>SHORT_BASE+l.code);
  const now     = new Date().toISOString().split('T')[0];
  const xml = buildSitemapXML(allUrls, now);

  // Store it so the Sitemap panel shows up-to-date content
  try{ localStorage.setItem('lc_sitemap_xml', xml); }catch(e){}

  sitemapLog(`🗺 Sitemap updated — ${allUrls.length} URLs · lastmod ${now}`);

  // Fire crawl signals for the new URLs only
  await fireSitemapSignals(newShortUrls, xml, 'auto');
}

function buildSitemapXML(urls, lastmod){
  const entries = urls.map(u=>`  <url>
    <loc>${he(u)}</loc>
    <lastmod>${lastmod}</lastmod>
    <changefreq>daily</changefreq>
    <priority>0.8</priority>
  </url>`).join('\n');
  return `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
${entries}
</urlset>`;
}

// Central sitemap signal blaster — used by auto + manual
async function fireSitemapSignals(shortUrls, xml, logTarget='idx'){
  const log = logTarget==='auto' ? sitemapLog : idxLog;
  const smEnc = encodeURIComponent(SITEMAP_URL);

  // 1. Google sitemap ping
  try{
    await fetch(`https://www.google.com/ping?sitemap=${smEnc}`,{mode:'no-cors'});
    log('🗺 Google sitemap ping sent','ok');
  }catch(e){}

  // 2. Bing sitemap ping
  try{
    await fetch(`https://www.bing.com/ping?sitemap=${smEnc}`,{mode:'no-cors'});
    log('🗺 Bing sitemap ping sent','ok');
  }catch(e){}

  // 3. PubSubHubbub for sitemap feed
  try{
    const b=new URLSearchParams();
    b.append('hub.mode','publish');
    b.append('hub.url', SITEMAP_URL);
    b.append('hub.url', FEED_URL);
    await fetch('https://pubsubhubbub.appspot.com/',{method:'POST',body:b,mode:'no-cors'});
    log('📢 PubSubHubbub notified (sitemap + feed)','ok');
  }catch(e){}

  // 4. WebSub (W3C standard) to multiple hubs
  const webSubHubs = [
    'https://pubsubhubbub.appspot.com/',
    'https://pubsubhubbub.superfeedr.com/',
  ];
  for(const hub of webSubHubs){
    try{
      const b=new URLSearchParams();
      b.append('hub.mode','publish');
      b.append('hub.url', SITEMAP_URL);
      await fetch(hub,{method:'POST',body:b,mode:'no-cors'});
    }catch(e){}
  }
  log('🌐 WebSub hubs notified','ok');
}

function sitemapLog(msg, type='ok'){
  // Show in a sitemap log section if visible, else silent
  const el = document.getElementById('sitemap-log');
  if(el){
    el.style.display='block';
    el.innerHTML += `<div class="log-${type}">${msg}</div>`;
    el.scrollTop = el.scrollHeight;
  }
}

// ══════════════════════════════════════════════════════════
// GSC TOKEN (multi-scope)
// ══════════════════════════════════════════════════════════
async function getToken(saJson, scope){
  const sa=JSON.parse(saJson);
  const now=Math.floor(Date.now()/1000);
  const b64url=obj=>btoa(JSON.stringify(obj)).replace(/=/g,'').replace(/\+/g,'-').replace(/\//g,'_');
  const sigInput=b64url({alg:'RS256',typ:'JWT'})+'.'+b64url({iss:sa.client_email,scope,aud:'https://oauth2.googleapis.com/token',iat:now,exp:now+3600});
  const pemBody=sa.private_key.replace(/-----[^-]+-----/g,'').replace(/\s/g,'');
  const keyDer=Uint8Array.from(atob(pemBody),c=>c.charCodeAt(0));
  const cryptoKey=await crypto.subtle.importKey('pkcs8',keyDer.buffer,{name:'RSASSA-PKCS1-v1_5',hash:'SHA-256'},false,['sign']);
  const sig=await crypto.subtle.sign('RSASSA-PKCS1-v1_5',cryptoKey,new TextEncoder().encode(sigInput));
  const sigB64=btoa(String.fromCharCode(...new Uint8Array(sig))).replace(/=/g,'').replace(/\+/g,'-').replace(/\//g,'_');
  const resp=await fetch('https://oauth2.googleapis.com/token',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:`grant_type=urn%3Aietf%3Aparams%3Aoauth%3Agrant-type%3Ajwt-bearer&assertion=${sigInput}.${sigB64}`});
  const td=await resp.json();
  if(!td.access_token) throw new Error(td.error_description||'Token failed');
  return td.access_token;
}

