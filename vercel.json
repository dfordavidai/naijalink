// ══════════════════════════════════════════════════════════
// GOOGLEBOT FOOTER FEED
// ══════════════════════════════════════════════════════════
let botFeedEvents = [];
async function refreshBotFeed(){
  try{
    const rows = await sbGet('ic_short_links?hits=gt.0&order=updated_at.desc&limit=60&select=code,hits,updated_at');
    if(!rows||!rows.length){ renderBotFeed([]); return; }
    const allLinks = Object.values(links).flat();
    const events = rows.map(row=>{
      const lnk  = allLinks.find(l=>l.code===row.code);
      const proj = lnk ? projects.find(p=>p.id===lnk.project_id) : null;
      return { code:row.code, hits:row.hits||0, time:row.updated_at||null, projName:proj?proj.name:'Unknown', original:lnk?lnk.original:null };
    });
    botFeedEvents = events;
    renderBotFeed(events);
  }catch(e){}
}
function renderBotFeed(events){
  const inner = document.getElementById('bot-feed-inner');
  if(!events.length){
    inner.style.animation='none';
    inner.innerHTML=`<div class="bot-empty-feed">⏳ No bot hits yet — submit links &amp; wait for Googlebot</div>`;
    return;
  }
  const chips = events.map(ev=>{
    const timeStr  = ev.time ? relTime(ev.time) : '—';
    const projLabel= ev.projName.length>18 ? ev.projName.slice(0,16)+'…' : ev.projName;
    return `<div class="bot-event" title="${ev.original?he(ev.original):''}">
      <span class="be-icon">🤖</span>
      <span class="be-time">${timeStr}</span>
      <span class="be-sep">·</span>
      <span class="be-proj">${he(projLabel)}</span>
      <span class="be-sep">›</span>
      <span class="be-code">${he(ev.code)}</span>
      <span class="be-sep">·</span>
      <span class="be-hits">${ev.hits} hit${ev.hits!==1?'s':''}</span>
    </div>`;
  }).join('');
  inner.innerHTML = chips + chips;
  requestAnimationFrame(()=>{
    const halfW = inner.scrollWidth / 2;
    const dur   = Math.max(20, halfW / 60);
    inner.style.animation = `none`;
    inner.offsetHeight;
    inner.style.animation = `scrollFeed ${dur}s linear infinite`;
  });
}
function relTime(iso){
  try{
    const diff = Date.now() - new Date(iso).getTime();
    const m = Math.floor(diff/60000);
    if(m < 1)  return 'just now';
    if(m < 60) return `${m}m ago`;
    const h = Math.floor(m/60);
    if(h < 24) return `${h}h ago`;
    return `${Math.floor(h/24)}d ago`;
  }catch(e){ return '—'; }
}
document.addEventListener('DOMContentLoaded',()=>{
  const inner = document.getElementById('bot-feed-inner');
  if(inner){
    inner.addEventListener('mouseenter',()=>inner.classList.add('paused'));
    inner.addEventListener('mouseleave',()=>inner.classList.remove('paused'));
  }
  // FIX: moved inside DOMContentLoaded — was crashing on null and breaking ALL click handlers
  const projInput = document.getElementById('proj-name-input');
  if(projInput) projInput.addEventListener('keydown',e=>{ if(e.key==='Enter') createProject(); });
});

