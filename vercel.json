async function openCrawlDetails(shortUrl, originalUrl){
  document.getElementById('modal-crawl').classList.add('open');
  const urlBar = document.getElementById('crawl-url-bar');
  urlBar.innerHTML = `<span>Short:</span> ${he(shortUrl)} &nbsp;→&nbsp; <span>Original:</span> ${he(originalUrl.slice(0,70))}${originalUrl.length>70?'…':''}`;
  const sections = document.getElementById('crawl-sections');
  sections.innerHTML = `<div class="crawl-loading"><div class="spin">⟳</div><div>Querying Google Search Console…</div></div>`;
  loadPagePreview(originalUrl);

  const sa   = getNextSA();
  const site = document.getElementById('gsc-site').value.trim()||'https://tinubunews.com.ng/';

  if(!sa){
    sections.innerHTML = `<div class="crawl-no-sa">
      <div class="ns-icon">🔑</div>
      <div style="margin-bottom:8px;color:var(--text);font-size:.72rem">Service Account Required</div>
      <div>Add SA keys in <strong style="color:var(--accent)">Settings & Keys</strong> tab to enable crawl inspection.</div>
    </div>`;
    return;
  }
  try{
    const token = await getToken(sa.json,'https://www.googleapis.com/auth/webmasters');
    const r = await fetch('https://searchconsole.googleapis.com/v1/urlInspection/index:inspect',{
      method:'POST',
      headers:{'Authorization':`Bearer ${token}`,'Content-Type':'application/json'},
      body:JSON.stringify({inspectionUrl:shortUrl, siteUrl:site})
    });
    if(!r.ok){ const t=await r.text(); sections.innerHTML=`<div class="crawl-error">❌ GSC API ${r.status}: ${he(t.slice(0,200))}</div>`; return; }
    const data = await r.json();
    renderCrawlDetails(sections, data?.inspectionResult||{}, shortUrl, originalUrl);
  }catch(e){
    sections.innerHTML=`<div class="crawl-error">❌ ${he(e.message)}</div>`;
  }
}

function loadPagePreview(url){
  const wrap   = document.getElementById('cpf-img-wrap');
  const metaEl = document.getElementById('crawl-meta-mini');
  const openBtn= document.getElementById('open-orig-btn');
  openBtn.href = url; openBtn.style.display='block';
  const screenshotUrl = `https://image.thum.io/get/width/520/crop/900/noanimate/${encodeURIComponent(url)}`;
  wrap.innerHTML=`<div class="cpf-loading"><div class="spin" style="font-size:1.2rem">⟳</div><div>Capturing…</div></div>`;
  const img=new Image();
  img.onload=()=>{
    wrap.innerHTML=''; img.className='cpf-img'; img.alt='Page preview'; wrap.appendChild(img);
    try{
      const u=new URL(url);
      metaEl.style.display='flex';
      metaEl.innerHTML=`
        <div class="cmm-row"><span class="cmm-k">Domain</span><span class="cmm-v blue">${he(u.hostname)}</span></div>
        <div class="cmm-row"><span class="cmm-k">Protocol</span><span class="cmm-v ${u.protocol==='https:'?'good':'warn'}">${he(u.protocol.replace(':',''))}</span></div>
        <div class="cmm-row"><span class="cmm-k">Path</span><span class="cmm-v" style="font-size:.5rem;overflow:hidden;max-width:130px;white-space:nowrap">${he(u.pathname||'/')}</span></div>`;
    }catch(e){}
  };
  img.onerror=()=>{
    try{
      const u=new URL(url);
      wrap.innerHTML=`<div class="cpf-error"><img src="https://www.google.com/s2/favicons?domain=${u.hostname}&sz=32" style="width:32px;border-radius:6px;margin-bottom:4px"><div style="color:var(--text);font-size:.65rem;font-weight:700">${he(u.hostname)}</div><div style="font-size:.52rem;margin-top:4px">Screenshot unavailable</div></div>`;
      metaEl.style.display='flex';
      metaEl.innerHTML=`<div class="cmm-row"><span class="cmm-k">Domain</span><span class="cmm-v blue">${he(u.hostname)}</span></div>`;
    }catch(e){ wrap.innerHTML='<div class="cpf-error">Preview unavailable</div>'; }
  };
  img.src=screenshotUrl;
}

function renderCrawlDetails(container, res, shortUrl, originalUrl){
  const idx  = res.indexStatusResult||{};
  const mob  = res.mobileUsabilityResult||{};
  const rich = res.richResultsResult||{};
  const amp  = res.ampResult||{};

  const verdict = idx.verdict||'UNKNOWN';
  const vClass  = verdict==='PASS'?'pass': verdict==='NEUTRAL'?'neutral': verdict==='FAIL'?'fail':'pending';
  const vIcon   = verdict==='PASS'?'✅': verdict==='NEUTRAL'?'🔵': verdict==='FAIL'?'❌':'⏳';
  const vLabel  = verdict==='PASS'?'Indexed': verdict==='NEUTRAL'?'Crawled / Not Indexed': verdict==='FAIL'?'Not Indexed (Error)':'Unknown / Pending';

  let html=`<div class="crawl-verdict-banner ${vClass}">
    <span class="cvb-icon">${vIcon}</span>
    <div><div class="cvb-label ${vClass}">${vLabel}</div>${idx.coverageState?`<div class="cvb-sub">${he(idx.coverageState)}</div>`:''}</div>
  </div>
  <div class="crawl-section">
    <div class="crawl-section-hdr" style="background:rgba(0,255,136,0.04)"><span class="cs-icon">📄</span><span style="color:var(--accent)">Index Status</span></div>
    <div class="crawl-section-body">
      ${kv('Verdict',verdict,vClass)}
      ${kv('Coverage State',idx.coverageState||'—')}
      ${kv('Robots.txt',idx.robotsTxtState||'—',robotsColor(idx.robotsTxtState))}
      ${kv('Indexing State',idx.indexingState||'—',indexingColor(idx.indexingState))}
      ${kv('Page Fetch',idx.pageFetchState||'—',fetchColor(idx.pageFetchState))}
      ${kv('Last Crawl',idx.lastCrawlTime?fmtDate(idx.lastCrawlTime):'—',idx.lastCrawlTime?'good':'')}
      ${kv('Crawled As',idx.crawledAs||'—','blue')}
      ${kv('Google Canonical',idx.googleCanonical?shortUrl===idx.googleCanonical?'✓ Matches':'⚠ '+idx.googleCanonical.slice(0,50):'—',idx.googleCanonical&&idx.googleCanonical===shortUrl?'good':'warn')}
      ${kv('Sitemap',(idx.sitemap&&idx.sitemap.length)?idx.sitemap[0].slice(0,50)+'…':'—')}
      ${kv('Referring URLs',(idx.referringUrls&&idx.referringUrls.length)?idx.referringUrls.length+' found':'None',idx.referringUrls?.length?'good':'')}
    </div>
  </div>`;

  const mobVerdict=mob.verdict||'—';
  const mobIssues=mob.issues||[];
  html+=`<div class="crawl-section">
    <div class="crawl-section-hdr" style="background:rgba(59,130,246,0.04)"><span class="cs-icon">📱</span><span style="color:var(--blue)">Mobile Usability</span></div>
    <div class="crawl-section-body ${mobIssues.length?'single':''}">
      ${mobIssues.length?mobIssues.map(i=>`<div class="crawl-kv"><div class="ck">Issue</div><div class="cv bad">${he(i.issueType||i)}</div></div>`).join(''):kv('Status',mobVerdict==='PASS'?'✓ Mobile Friendly':mobVerdict==='FAIL'?'✗ Issues Found':mobVerdict==='—'?'No data':'Checking…',mobVerdict==='PASS'?'good':mobVerdict==='FAIL'?'bad':'')}
    </div>
  </div>`;

  if(rich.verdict||(rich.detectedItems&&rich.detectedItems.length)){
    const ri=rich.detectedItems||[];
    html+=`<div class="crawl-section">
      <div class="crawl-section-hdr" style="background:rgba(168,85,247,0.04)"><span class="cs-icon">✨</span><span style="color:var(--purple)">Rich Results</span></div>
      <div class="crawl-section-body ${ri.length?'single':''}">
        ${ri.length?ri.map(i=>`<div class="crawl-kv"><div class="ck">${he(i.richResultType||'Type')}</div><div class="cv blue">${(i.items||[]).length} items</div></div>`).join(''):kv('Status',rich.verdict||'—',rich.verdict==='PASS'?'good':rich.verdict==='FAIL'?'bad':'')}
      </div>
    </div>`;
  }

  if(amp.verdict){
    html+=`<div class="crawl-section">
      <div class="crawl-section-hdr" style="background:rgba(245,158,11,0.04)"><span class="cs-icon">⚡</span><span style="color:var(--orange)">AMP</span></div>
      <div class="crawl-section-body">
        ${kv('AMP Status',amp.verdict||'—',amp.verdict==='PASS'?'good':amp.verdict==='FAIL'?'bad':'')}
        ${amp.ampUrl?kv('AMP URL',amp.ampUrl.slice(0,50)+'…'):''}
      </div>
    </div>`;
  }

  if(idx.referringUrls&&idx.referringUrls.length){
    html+=`<div class="crawl-section">
      <div class="crawl-section-hdr" style="background:rgba(0,255,136,0.04)"><span class="cs-icon">🔗</span><span style="color:var(--accent)">Referring URLs (${idx.referringUrls.length})</span></div>
      <div class="crawl-section-body single">
        ${idx.referringUrls.map(u=>`<div class="crawl-kv"><div class="cv blue" style="font-size:.62rem"><a href="${he(u)}" target="_blank" style="color:var(--blue);text-decoration:none">${he(u.slice(0,80))}${u.length>80?'…':''}</a></div></div>`).join('')}
      </div>
    </div>`;
  }

  html+=`<div class="crawl-section" id="psi-section">
    <div class="crawl-section-hdr" style="background:rgba(245,158,11,0.04)"><span class="cs-icon">⚡</span><span style="color:var(--orange)">PageSpeed Scores</span><span style="margin-left:auto;font-size:.48rem;color:var(--muted2)">via Google PSI</span></div>
    <div class="crawl-section-body" id="psi-body"><div class="crawl-kv"><div class="cv" style="color:var(--muted2);font-size:.6rem">⟳ Loading…</div></div></div>
  </div>`;

  container.innerHTML=html;
  if(originalUrl) loadPageSpeedScores(originalUrl);
}

async function loadPageSpeedScores(url){
  const body=document.getElementById('psi-body'); if(!body) return;
  try{
    const [mobR,deskR]=await Promise.all([
      fetch(`https://www.googleapis.com/pagespeedonline/v5/runPagespeed?url=${encodeURIComponent(url)}&strategy=mobile&category=performance&category=accessibility&category=seo`),
      fetch(`https://www.googleapis.com/pagespeedonline/v5/runPagespeed?url=${encodeURIComponent(url)}&strategy=desktop&category=performance&category=seo`)
    ]);
    if(!mobR.ok&&!deskR.ok){ body.innerHTML=`<div class="crawl-kv"><div class="cv warn">PSI unavailable</div></div>`; return; }
    const score=(data,cat)=>{ const s=data?.lighthouseResult?.categories?.[cat]?.score; return s!=null?Math.round(s*100):null; };
    const sc=s=>s==null?'':s>=90?'good':s>=50?'warn':'bad';
    const ss=s=>s==null?'—':s+'';
    const md=mobR.ok?await mobR.json():null;
    const dd=deskR.ok?await deskR.json():null;
    const fcp=md?.lighthouseResult?.audits?.['first-contentful-paint']?.displayValue||'—';
    const lcp=md?.lighthouseResult?.audits?.['largest-contentful-paint']?.displayValue||'—';
    const cls=md?.lighthouseResult?.audits?.['cumulative-layout-shift']?.displayValue||'—';
    const tbt=md?.lighthouseResult?.audits?.['total-blocking-time']?.displayValue||'—';
    body.innerHTML=`
      <div class="crawl-kv"><div class="ck">📱 Mobile Perf</div><div class="cv ${sc(score(md,'performance'))}">${ss(score(md,'performance'))}/100</div></div>
      <div class="crawl-kv"><div class="ck">🖥 Desktop Perf</div><div class="cv ${sc(score(dd,'performance'))}">${ss(score(dd,'performance'))}/100</div></div>
      <div class="crawl-kv"><div class="ck">♿ Accessibility</div><div class="cv ${sc(score(md,'accessibility'))}">${ss(score(md,'accessibility'))}/100</div></div>
      <div class="crawl-kv"><div class="ck">🔍 SEO Score</div><div class="cv ${sc(score(md,'seo'))}">${ss(score(md,'seo'))}/100</div></div>
      <div class="crawl-kv"><div class="ck">⏱ FCP</div><div class="cv">${he(fcp)}</div></div>
      <div class="crawl-kv"><div class="ck">🖼 LCP</div><div class="cv">${he(lcp)}</div></div>
      <div class="crawl-kv"><div class="ck">📐 CLS</div><div class="cv">${he(cls)}</div></div>
      <div class="crawl-kv"><div class="ck">🚧 TBT</div><div class="cv">${he(tbt)}</div></div>`;
  }catch(e){ if(body) body.innerHTML=`<div class="crawl-kv"><div class="cv warn">PSI failed: ${he(e.message)}</div></div>`; }
}

// ══════════════════════════════════════════════════════════
// UTILITIES
// ══════════════════════════════════════════════════════════
function kv(key,val,cls=''){
  return `<div class="crawl-kv"><div class="ck">${he(key)}</div><div class="cv ${cls}">${he(String(val))}</div></div>`;
}
function fmtDate(iso){ try{ return new Date(iso).toLocaleString(); }catch(e){ return iso; } }
function robotsColor(s){ return !s||s==='ALLOWED'?'good': s==='DISALLOWED'?'bad':'warn'; }
function indexingColor(s){ return !s||s==='INDEXING_ALLOWED'?'good': s.includes('BLOCKED')||s.includes('FORBIDDEN')?'bad':'warn'; }
function fetchColor(s){ return !s||s==='SUCCESSFUL'?'good': s==='SOFT_404'||s==='REDIRECT_ERROR'?'warn': s==='ACCESS_DENIED'||s==='NOT_FOUND'?'bad':''; }
function he(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
</script>


</body></html>
