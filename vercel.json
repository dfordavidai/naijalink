            <div class="cpf-loading" id="cpf-loading"><div class="spin" style="font-size:1.2rem">⟳</div><div>Loading preview…</div></div>
          </div>
        </div>
        <div class="crawl-meta-mini" id="crawl-meta-mini" style="display:none"></div>
        <a class="open-orig-btn" id="open-orig-btn" href="#" target="_blank" style="display:none">↗ Open Original Page</a>
      </div>
      <!-- Data column -->
      <div class="crawl-sections" id="crawl-sections">
        <div class="crawl-loading">
          <div class="spin">⟳</div>
          <div>Loading crawl data…</div>
