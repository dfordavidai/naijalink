  const sel = document.getElementById('social-proj-sel');
  if(!sel) return;
  const cur = sel.value;
  sel.innerHTML = '<option value="">— Choose a project —</option>'+
    projects.map(p=>`<option value="${p.id}">${he(p.name)}</option>`).join('');
