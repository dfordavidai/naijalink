// ══════════════════════════════════════════════════════════
// MAIN INDEXING RUN
// ══════════════════════════════════════════════════════════
async function runIndexing(){
  const pid  = document.getElementById('idx-proj-sel').value;
  const site = document.getElementById('gsc-site').value.trim()||'https://tinubunews.com.ng/';
  if(!pid){ toast('Select a project first',''); return; }
  const pl = links[pid]||[];
  const shortUrls = pl.map(l=>SHORT_BASE+l.code);
  if(!shortUrls.length){ toast('No links in this project',''); return; }

  const btn=document.getElementById('idx-btn');
  btn.disabled=true; btn.textContent='⏳ Blasting…';
  document.getElementById('idx-log').innerHTML='';
  setProgress(2);

  const total = shortUrls.length;
  idxLog(`🚀 Blasting ${total} URLs across all enabled channels…`,'info');

  let done = 0;
  const tick = () => { done++; setProgress(Math.round((done/total)*100)); };

  // ── 1. GSC URL Inspection + Indexing API (dual-fire per SA) ──
  if(chanSettings.gsc || chanSettings.idxApi){
    const sa = getNextSA();
    if(!sa){
      idxLog('⚠ No SA keys available — skipping GSC channels. Add keys in Settings.','err');
    } else {
      try{
        idxLog('🔑 Authenticating…','info');
        const [tokenGSC, tokenIdx] = await Promise.all([
          chanSettings.gsc    ? getToken(sa.json,'https://www.googleapis.com/auth/webmasters') : null,
          chanSettings.idxApi ? getToken(sa.json,'https://www.googleapis.com/auth/indexing')   : null
        ]);

        let currentSA = sa;
        let currentGSCToken = tokenGSC;
        let currentIdxToken = tokenIdx;

        for(const l of pl){
          const shortUrl = SHORT_BASE+l.code;

          // Rotate SA if quota hit
          if(currentSA.daily_used>=200){
            const next = getNextSA();
            if(!next){ idxLog('⚠ All SA keys at quota limit for today','err'); break; }
            currentSA = next;
            idxLog(`🔄 Rotated to SA key: ${currentSA.label}`,'info');
            if(chanSettings.gsc)    currentGSCToken = await getToken(currentSA.json,'https://www.googleapis.com/auth/webmasters');
            if(chanSettings.idxApi) currentIdxToken = await getToken(currentSA.json,'https://www.googleapis.com/auth/indexing');
          }

          // Fire both APIs in parallel
          const fires = [];

          if(chanSettings.gsc && currentGSCToken){
            fires.push(
              fetch('https://searchconsole.googleapis.com/v1/urlInspection/index:inspect',{
                method:'POST',
                headers:{'Authorization':`Bearer ${currentGSCToken}`,'Content-Type':'application/json'},
                body:JSON.stringify({inspectionUrl:shortUrl, siteUrl:site})
              }).then(async r=>{
                if(r.status===429){ idxLog('⚠ GSC quota hit — rotating key','err'); currentSA.daily_used=200; return; }
                if(r.ok){
                  const d=await r.json();
                  const v=d?.inspectionResult?.indexStatusResult?.verdict||'SUBMITTED';
                  await sbPatch('lc_links',`id=eq.${l.id}`,{verdict:v,submitted:true,retry_count:0});
                  l.verdict=v; l.submitted=true;
                  idxLog(`🔍 GSC: ${l.code} → ${v}`,'ok');
                  currentSA.daily_used++;
                }
              }).catch(e=>idxLog(`✗ GSC ${l.code}: ${e.message}`,'err'))
            );
          }

          if(chanSettings.idxApi && currentIdxToken){
            fires.push(
              fetch('https://indexing.googleapis.com/v3/urlNotifications:publish',{
                method:'POST',
                headers:{'Authorization':`Bearer ${currentIdxToken}`,'Content-Type':'application/json'},
                body:JSON.stringify({url:shortUrl, type:'URL_UPDATED'})
              }).then(r=>{
                if(r.ok){ idxLog(`⚡ IndexAPI: ${l.code} → queued`,'ok'); currentSA.daily_used++; }
                else { idxLog(`⚡ IndexAPI: ${l.code} → HTTP ${r.status}`,'info'); }
              }).catch(e=>idxLog(`✗ IdxAPI ${l.code}: ${e.message}`,'err'))
            );
          }

          await Promise.all(fires);
          tick();
          await new Promise(r=>setTimeout(r,320));
        }

        localStorage.setItem('lc_sa_vault', JSON.stringify(saVault));
        renderSAVault();
        renderSAStatus();
      }catch(e){ idxLog(`✗ SA auth error: ${e.message}`,'err'); }
    }
  }

  // ── 2. GSC Sitemaps API — DELETE + RE-ADD ──
  if(chanSettings.sitemapApi){
    idxLog('🗺 GSC Sitemaps API — delete + re-add…','info');
    const sa = getNextSA();
    if(sa){
      try{
        const t = await getToken(sa.json,'https://www.googleapis.com/auth/webmasters');
        const siteEnc = encodeURIComponent(site);
        const smEnc   = encodeURIComponent(SITEMAP_URL);
        const base    = `https://searchconsole.googleapis.com/webmasters/v3/sites/${siteEnc}/sitemaps/${smEnc}`;
        const hdrs    = {'Authorization':`Bearer ${t}`,'Content-Type':'application/json'};
        await fetch(base,{method:'DELETE',headers:hdrs});
        await new Promise(r=>setTimeout(r,800));
        const r = await fetch(base,{method:'PUT',headers:hdrs});
        idxLog(r.ok||r.status===204 ? '🗺 Sitemap API: deleted + re-submitted ✓' : `🗺 Sitemap re-add: HTTP ${r.status}`,'ok');
      }catch(e){ idxLog(`⚠ Sitemap API: ${e.message}`,'info'); }
    } else {
      idxLog('⚠ Sitemap API: no SA key available','info');
    }
  }

  // ── 3. IndexNow — all endpoints simultaneously ──
  if(chanSettings.indexnow){
    idxLog('📡 IndexNow → all engines simultaneously…','info');
    const payload = JSON.stringify({
      host:'tinubunews.com.ng',
      key: INDEXNOW_KEY,
      keyLocation: INDEXNOW_KEY_LOC,
      urlList: shortUrls
    });
    const inEndpoints = [
      'https://api.indexnow.org/indexnow',
      'https://www.bing.com/indexnow',
      'https://yandex.com/indexnow',
      'https://search.seznam.cz/indexnow',
      'https://indexnow.org/indexnow',
    ];
    const results = await Promise.allSettled(
      inEndpoints.map(ep=>fetch(ep,{method:'POST',headers:{'Content-Type':'application/json; charset=utf-8'},body:payload}))
    );
    const ok = results.filter(r=>r.status==='fulfilled'&&(r.value.ok||r.value.status===202||r.value.status===200)).length;
    idxLog(`📡 IndexNow: ${ok}/${inEndpoints.length} endpoints accepted ${total} URLs`,'ok');
  }

  // ── 4. Bing Webmaster Direct API ──
  if(chanSettings.bing){
    const bKey = document.getElementById('bing-api-key')?.value.trim()||localStorage.getItem('lc_bing_key')||'';
    if(bKey){
      idxLog('🔎 Bing Webmaster direct API…','info');
      try{
        const r = await fetch(`https://ssl.bing.com/webmaster/api.svc/json/SubmitUrlbatch?apikey=${encodeURIComponent(bKey)}`,{
          method:'POST',
          headers:{'Content-Type':'application/json; charset=utf-8'},
          body:JSON.stringify({siteUrl:'https://tinubunews.com.ng', urlList:shortUrls.slice(0,500)})
        });
        idxLog(r.ok ? `🔎 Bing Webmaster: ${Math.min(shortUrls.length,500)} URLs submitted ✓` : `🔎 Bing: HTTP ${r.status}`,'ok');
      }catch(e){ idxLog(`⚠ Bing API: ${e.message}`,'info'); }
    } else {
      idxLog('⚠ Bing Webmaster: no API key set (add in Settings → Channels)','info');
    }
  }

  // ── 5. PubSubHubbub + WebSub triple-fire ──
  if(chanSettings.pubsub){
    idxLog('📢 PubSub + WebSub triple-fire…','info');
    await fireSitemapSignals(shortUrls, null, 'idx');
  }

  // ── 6. XML-RPC Ping Blast (20+ services) ──
  if(chanSettings.xmlrpc){
    idxLog('💥 XML-RPC ping blast (20 services)…','info');
    await xmlrpcPingBlast(shortUrls[0]||SITEMAP_URL, 'idx');
  }

  // ── 7. Rapid URL Indexer (paid) ──
  if(chanSettings.rui){
    const ruiKey = document.getElementById('rui-api-key')?.value.trim()||localStorage.getItem('lc_rui_key')||'';
    if(ruiKey){
      idxLog('🌀 Rapid URL Indexer…','info');
      try{
        const r=await fetch('https://rapidurlindexer.com/api/v1/submit',{
          method:'POST',
          headers:{'Content-Type':'application/json','Authorization':`Bearer ${ruiKey}`},
          body:JSON.stringify({urls:shortUrls})
        });
        idxLog(r.ok?`🌀 RUI: ${total} URLs submitted ✓`:`🌀 RUI: HTTP ${r.status}`,'ok');
      }catch(e){ idxLog(`⚠ RUI: ${e.message}`,'info'); }
    } else {
      idxLog('⚠ Rapid URL Indexer: no API key (add in Channels tab)','info');
    }
  }

  // ── 8. Mark remaining as submitted ──
  for(const l of pl){
    if(!l.submitted){
      await sbPatch('lc_links',`id=eq.${l.id}`,{submitted:true});
      l.submitted=true;
    }
  }

  setProgress(100);
  idxLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━','info');
  idxLog(`✅ Blast complete — ${total} URLs across all channels`,'ok');

  // Auto-generate social drafts if enabled
  if(chanSettings.t2){
    idxLog('📣 Social drafts ready — see Social Push tab','info');
    document.getElementById('social-proj-sel').value = pid;
  }

  btn.disabled=false; btn.textContent='🚀 Blast All Enabled Channels';
  renderAll();
  refreshBotFeed();
  toast(`🚀 ${total} URLs blasted!`,'green');
}

// ══════════════════════════════════════════════════════════
// XML-RPC PING BLAST
// ══════════════════════════════════════════════════════════
async function xmlrpcPingBlast(targetUrl, logTarget='idx'){
  const log = logTarget==='esc' ? escLog : idxLog;
  const endpoints = [
    'https://rpc.pingomatic.com/',
    'https://ping.blo.gs/',
    'https://rpc.weblogs.com/RPC2',
    'https://blogsearch.google.com/ping/RPC2',
    'https://ping.feedburner.com/',
    'https://www.blogdigger.com/RPC2',
    'https://www.blogsnow.com/ping',
    'https://ping.blogs.yandex.ru/RPC2',
    'https://www.icerocket.com/c?tab=blog&url=',
    'https://api.moreover.com/ping?u=',
    'https://ping.feedburner.com/',
    'https://www.bloghub.com/ping.php',
    'https://trackback.bakedalaska.com/ping',
    'https://rpc.technorati.com/rpc/ping',
    'https://ping.syndic8.com/xmlrpc.php',
    'https://www.blogrolling.com/ping.srv',
    'https://services.newsgator.com/ngws/xmlrpcping.aspx',
    'https://coreblog.org/ping/',
    'https://ping.rootblog.com/rpc.php',
    'https://www.blogpeople.net/servlet/weblogUpdates',
  ];
  const body = xmlRpcBody('tinubunews.com.ng', targetUrl);
  const results = await Promise.allSettled(
    endpoints.map(ep=>fetch(ep,{method:'POST',headers:{'Content-Type':'text/xml'},body,mode:'no-cors'}))
  );
  const fired = results.length;
  log(`💥 XML-RPC: pinged ${fired} services with ${he(targetUrl.slice(0,50))}…`,'ok');
}

function xmlRpcBody(name, url){
  return `<?xml version="1.0"?><methodCall><methodName>weblogUpdates.ping</methodName><params><param><value><string>${name}</string></value></param><param><value><string>${url}</string></value></param></params></methodCall>`;
}

// ══════════════════════════════════════════════════════════
// SITEMAP VIEWER — live XML preview
// ══════════════════════════════════════════════════════════
function viewSitemap(){
  const allUrls = Object.values(links).flat().map(l=>SHORT_BASE+l.code);
  const now = new Date().toISOString().split('T')[0];
  const xml  = buildSitemapXML(allUrls, now);
  const win  = window.open('','_blank');
  win.document.write(`<pre style="font-family:monospace;font-size:13px;padding:20px;background:#09090b;color:#00ff88">${xml.replace(/</g,'&lt;')}</pre>`);
}

async function manualSitemapPing(){
  const allUrls = Object.values(links).flat().map(l=>SHORT_BASE+l.code);
  if(!allUrls.length){ toast('No links yet',''); return; }
  sitemapLog(`📡 Manual sitemap ping started — ${allUrls.length} URLs…`,'info');
  await fireSitemapSignals(allUrls, null, 'auto');
  sitemapLog('✅ Manual sitemap ping complete','ok');
  toast('📡 Sitemap signals fired','green');
}

// ══════════════════════════════════════════════════════════
// ESCALATION LADDER
// ══════════════════════════════════════════════════════════
async function runEscalation(){
  const pid  = document.getElementById('esc-proj-sel').value;
  const site = document.getElementById('gsc-site').value.trim()||'https://tinubunews.com.ng/';
  document.getElementById('esc-log').innerHTML='';

  const targetLinks = pid==='all'
    ? Object.values(links).flat()
    : (links[pid]||[]);

  const neutral = targetLinks.filter(l=>
    (l.verdict==='NEUTRAL'||l.verdict==='crawled'||(!l.verdict||l.verdict==='pending'))&&l.submitted
  );

  if(!neutral.length){ escLog('✅ No NEUTRAL/pending links found — all good!','ok'); return; }
  escLog(`🔁 Found ${neutral.length} NEUTRAL links — running escalation…`,'info');

  for(const l of neutral){
    const rc    = (l.retry_count||0)+1;
    const short = SHORT_BASE+l.code;
    escLog(`— ${l.code} (retry #${rc})…`,'info');

    // Tier 1 & 2: always fire all core channels
    const sa = getNextSA();
    if(sa){
      try{
        const [tGSC,tIdx] = await Promise.all([
          getToken(sa.json,'https://www.googleapis.com/auth/webmasters'),
          getToken(sa.json,'https://www.googleapis.com/auth/indexing')
        ]);
        await Promise.all([
          fetch('https://searchconsole.googleapis.com/v1/urlInspection/index:inspect',{method:'POST',headers:{'Authorization':`Bearer ${tGSC}`,'Content-Type':'application/json'},body:JSON.stringify({inspectionUrl:short,siteUrl:site})}).then(async r=>{if(r.ok){const d=await r.json();const v=d?.inspectionResult?.indexStatusResult?.verdict;if(v){l.verdict=v;await sbPatch('lc_links',`id=eq.${l.id}`,{verdict:v,retry_count:rc});}}}),
          fetch('https://indexing.googleapis.com/v3/urlNotifications:publish',{method:'POST',headers:{'Authorization':`Bearer ${tIdx}`,'Content-Type':'application/json'},body:JSON.stringify({url:short,type:'URL_UPDATED'})})
        ]);
        sa.daily_used+=2;
        escLog(`  ✓ GSC + Indexing API fired`,'ok');
      }catch(e){ escLog(`  ⚠ SA error: ${e.message}`,'err'); }
    }

    // All retry tiers: IndexNow blast
    const payload=JSON.stringify({host:'tinubunews.com.ng',key:INDEXNOW_KEY,keyLocation:INDEXNOW_KEY_LOC,urlList:[short]});
    await Promise.allSettled(['https://api.indexnow.org/indexnow','https://www.bing.com/indexnow','https://yandex.com/indexnow'].map(ep=>fetch(ep,{method:'POST',headers:{'Content-Type':'application/json; charset=utf-8'},body:payload})));
    escLog(`  ✓ IndexNow fired`,'ok');

    // Tier 2+ (retry >= 2): also ping blast + sitemap re-add
    if(rc>=2){
      await xmlrpcPingBlast(short,'esc');
      await fireSitemapSignals([short],null,'esc');
      // Rapid URL Indexer if key set
      const ruiKey = localStorage.getItem('lc_rui_key');
      if(ruiKey){
        try{ await fetch('https://rapidurlindexer.com/api/v1/submit',{method:'POST',headers:{'Content-Type':'application/json','Authorization':`Bearer ${ruiKey}`},body:JSON.stringify({urls:[short]})}); escLog(`  ✓ RUI fired`,'ok'); }catch(e){}
      }
    }

    // Tier 3+ (retry >= 3): note that social drafts are available
    if(rc>=3){
      escLog(`  📣 Tier 3 — social drafts recommended for ${l.code}. Use Social Push tab.`,'info');
    }

    // Tier 4 (retry >= 4): flag for manual review
    if(rc>=4){
      escLog(`  🚨 ${l.code} has been retried 4+ times — manual review needed (check noindex, robots, thin content)`,'err');
      await sbPatch('lc_links',`id=eq.${l.id}`,{verdict:'FAIL',retry_count:rc});
      l.verdict='FAIL';
    } else {
      await sbPatch('lc_links',`id=eq.${l.id}`,{retry_count:rc});
      l.retry_count=rc;
    }

    await new Promise(r=>setTimeout(r,400));
  }

  localStorage.setItem('lc_sa_vault', JSON.stringify(saVault));
  renderSAVault(); renderSAStatus(); renderAll();
  escLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━','info');
  escLog(`✅ Escalation complete for ${neutral.length} links`,'ok');
  toast('🔁 Escalation done','green');
}

